<Window x:Class="Perelegans.Views.FloatingPetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Focus Agent"
        Width="184"
        Height="188"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        SizeToContent="Manual"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <DropShadowEffect x:Key="SoftShadow"
                          BlurRadius="18"
                          ShadowDepth="3"
                          Opacity="0.28"
                          Color="#20242A"/>
    </Window.Resources>

    <Grid Tag="{Binding}">
        <Grid.ContextMenu>
            <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                <MenuItem Header="{Binding MonitorMenuText}"
                          Command="{Binding ToggleMonitorCommand}"/>
                <MenuItem Header="{Binding FocusModeMenuText}"
                          Command="{Binding ToggleFocusModeCommand}"/>
                <Separator/>
                <MenuItem Header="设置"
                          Command="{Binding OpenSettingsCommand}"/>
                <Separator/>
                <MenuItem Header="退出"
                          Command="{Binding ExitCommand}"/>
            </ContextMenu>
        </Grid.ContextMenu>

        <Border HorizontalAlignment="Center"
                VerticalAlignment="Top"
                MaxWidth="168"
                Padding="10,7"
                Background="#F7FFFFFF"
                CornerRadius="8"
                Effect="{StaticResource SoftShadow}">
            <StackPanel>
                <TextBlock Text="{Binding BubbleText}"
                           Foreground="#252A31"
                           FontSize="12"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           LineHeight="17"/>
                <Button Content="{Binding BreakpointContinueText}"
                        Command="{Binding ContinueBreakpointCommand}"
                        Margin="0,7,0,0"
                        Padding="10,3"
                        HorizontalAlignment="Center"
                        FontSize="11"
                        Visibility="{Binding HasBreakpointPrompt, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </StackPanel>
        </Border>

        <Grid Width="118"
              Height="112"
              Margin="0,68,0,0"
              HorizontalAlignment="Center"
              VerticalAlignment="Top"
              Effect="{StaticResource SoftShadow}"
              RenderOptions.BitmapScalingMode="NearestNeighbor">
            <Ellipse Width="84"
                     Height="18"
                     Margin="0,84,0,0"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Top"
                     Fill="#30FF9BB9"/>
            <Border Width="112"
                    Height="104"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    ClipToBounds="True">
                <Image x:Name="PetSpriteImage"
                       Width="112"
                       Height="112"
                       Stretch="Uniform"
                       SnapsToDevicePixels="True"
                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
            </Border>
        </Grid>
    </Grid>
</Window>
