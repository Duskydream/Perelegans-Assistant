<Window x:Class="Perelegans.Views.FloatingPetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Focus Agent"
        Width="184"
        Height="188"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        SizeToContent="Manual"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Window.Resources>
        <DropShadowEffect x:Key="SoftShadow"
                          BlurRadius="18"
                          ShadowDepth="3"
                          Opacity="0.28"
                          Color="#20242A"/>
    </Window.Resources>

    <Grid Tag="{Binding}">
        <Grid.ContextMenu>
            <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                <MenuItem Header="设置"
                          Command="{Binding OpenSettingsCommand}"/>
                <Separator/>
                <MenuItem Header="退出"
                          Command="{Binding ExitCommand}"/>
            </ContextMenu>
        </Grid.ContextMenu>

        <Border HorizontalAlignment="Center"
                VerticalAlignment="Top"
                MaxWidth="168"
                Padding="10,7"
                Background="#F7FFFFFF"
                CornerRadius="8"
                Effect="{StaticResource SoftShadow}">
            <TextBlock Text="{Binding BubbleText}"
                       Foreground="#252A31"
                       FontSize="12"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       LineHeight="17"/>
        </Border>

        <Border Width="96"
                Height="96"
                Margin="0,72,0,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Background="#E9FFFFFF"
                CornerRadius="48"
                Effect="{StaticResource SoftShadow}">
            <Grid>
                <Ellipse Fill="#44A7E3D2"
                         Width="80"
                         Height="80"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"/>
                <Image Source="/Images/sho02A_101.png"
                       Width="86"
                       Height="86"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
