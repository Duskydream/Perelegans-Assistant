<mah:MetroWindow x:Class="Perelegans.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        Title="FocusArchive"
        TitleCharacterCasing="Normal"
        Width="980"
        Height="680"
        MinWidth="760"
        MinHeight="520"
        WindowStartupLocation="CenterScreen"
        ShowTitleBar="True"
        TitleBarHeight="32"
        BorderThickness="1"
        WindowTitleBrush="#FFC0CB"
        NonActiveWindowTitleBrush="#FFC0CB"
        GlowBrush="{DynamicResource MahApps.Brushes.Accent}"
        Background="{DynamicResource Perelegans.WindowBackground}"
        Foreground="{DynamicResource Perelegans.ForegroundBrush}">

    <mah:MetroWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style x:Key="SummaryCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Perelegans.PanelBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Perelegans.BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>
    </mah:MetroWindow.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,14">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="Refresh"
                        Width="86"
                        Height="30"
                        Margin="0,0,8,0"
                        Command="{Binding RefreshCommand}"
                        Style="{DynamicResource MahApps.Styles.Button.Square}"/>
                <Button Content="Monitor"
                        Width="86"
                        Height="30"
                        Margin="0,0,8,0"
                        Command="{Binding ToggleMonitorCommand}"
                        Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"/>
                <Button Content="Settings"
                        Width="86"
                        Height="30"
                        Margin="0,0,8,0"
                        Command="{Binding OpenSettingsCommand}"
                        Style="{DynamicResource MahApps.Styles.Button.Square}"/>
                <Button Content="Exit"
                        Width="72"
                        Height="30"
                        Command="{Binding ExitAppCommand}"
                        Style="{DynamicResource MahApps.Styles.Button.Square}"/>
            </StackPanel>

            <StackPanel>
                <TextBlock Text="FocusArchive"
                           FontSize="24"
                           FontWeight="SemiBold"/>
                <TextBlock Text="Application focus and foreground usage"
                           FontSize="12"
                           Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource SummaryCardStyle}">
                <StackPanel>
                    <TextBlock Text="Current App"
                               FontSize="11"
                               Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                    <TextBlock Text="{Binding CurrentProcessName}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding CurrentProcessDurationText}"
                               FontSize="12"
                               Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource SummaryCardStyle}">
                <StackPanel>
                    <TextBlock Text="Total Recorded"
                               FontSize="11"
                               Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                    <TextBlock Text="{Binding TotalDurationText}"
                               FontSize="18"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding ApplicationCount, StringFormat={}{0} applications}"
                               FontSize="12"
                               Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource SummaryCardStyle}">
                <StackPanel>
                    <TextBlock Text="Focus Mix"
                               FontSize="11"
                               Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                    <TextBlock Text="{Binding ProductiveCount, StringFormat={}{0} productive}"
                               FontSize="18"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding DistractingCount, StringFormat={}{0} distracting}"
                               FontSize="12"
                               Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Style="{StaticResource SummaryCardStyle}" Margin="0">
                <StackPanel>
                    <TextBlock Text="Live Signal"
                               FontSize="11"
                               Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                    <TextBlock Text="{Binding CurrentFocusLabel}"
                               FontSize="18"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding RecentSessionCountText, StringFormat={}{0} recent sessions}"
                               FontSize="12"
                               Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Header="Applications"
                      Margin="0,0,10,0"
                      BorderBrush="{DynamicResource Perelegans.BorderBrush}">
                <DataGrid ItemsSource="{Binding Applications}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          Background="{DynamicResource Perelegans.PanelBackground}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="App" Binding="{Binding DisplayName}" Width="160"/>
                        <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="110"/>
                        <DataGridTextColumn Header="Total" Binding="{Binding TotalDuration}" Width="110"/>
                        <DataGridTextColumn Header="Last Seen" Binding="{Binding LastSeenAt, StringFormat={}{0:g}}" Width="150"/>
                        <DataGridTextColumn Header="AI Note" Binding="{Binding LastAssistantMessage}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <GroupBox Grid.Column="1"
                      Header="Recent Sessions"
                      BorderBrush="{DynamicResource Perelegans.BorderBrush}">
                <DataGrid ItemsSource="{Binding RecentSessions}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          Background="{DynamicResource Perelegans.PanelBackground}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="App" Binding="{Binding ProcessName}" Width="120"/>
                        <DataGridTextColumn Header="Start" Binding="{Binding StartTime, StringFormat={}{0:t}}" Width="74"/>
                        <DataGridTextColumn Header="Duration" Binding="{Binding Duration}" Width="90"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </Grid>

        <DockPanel Grid.Row="3" Margin="0,14,0,0" LastChildFill="True">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="Backup"
                        Width="82"
                        Height="28"
                        Margin="0,0,8,0"
                        Command="{Binding SaveBackupCommand}"
                        Style="{DynamicResource MahApps.Styles.Button.Square}"/>
                <Button Content="Restore"
                        Width="82"
                        Height="28"
                        Margin="0,0,8,0"
                        Command="{Binding RestoreBackupCommand}"
                        Style="{DynamicResource MahApps.Styles.Button.Square}"/>
                <Button Content="Clear Data"
                        Width="92"
                        Height="28"
                        Command="{Binding ClearUsageDataCommand}"
                        Style="{DynamicResource MahApps.Styles.Button.Square}"/>
            </StackPanel>

            <TextBlock Text="{Binding StatusText}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
        </DockPanel>
    </Grid>
</mah:MetroWindow>
