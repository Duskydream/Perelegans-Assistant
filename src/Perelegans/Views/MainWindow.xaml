<mah:MetroWindow x:Class="Perelegans.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:i18n="clr-namespace:Perelegans.i18n"
        xmlns:models="clr-namespace:Perelegans.Models"
        Title="{i18n:Translate Main_WindowTitle}"
        TitleCharacterCasing="Normal"
        Width="1040"
        Height="720"
        MinWidth="820"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        ShowTitleBar="True"
        TitleBarHeight="32"
        BorderThickness="1"
        WindowTitleBrush="{DynamicResource Perelegans.PanelBackground}"
        NonActiveWindowTitleBrush="{DynamicResource Perelegans.PanelBackground}"
        GlowBrush="{DynamicResource Perelegans.BorderBrush}"
        Background="{DynamicResource Perelegans.WindowBackground}"
        Foreground="{DynamicResource Perelegans.ForegroundBrush}">

    <mah:MetroWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style x:Key="QuietTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="LineIconPathStyle" TargetType="Path">
            <Setter Property="Fill" Value="Transparent"/>
            <Setter Property="StrokeThickness" Value="1.45"/>
            <Setter Property="StrokeStartLineCap" Value="Round"/>
            <Setter Property="StrokeEndLineCap" Value="Round"/>
            <Setter Property="StrokeLineJoin" Value="Round"/>
            <Setter Property="Stretch" Value="Uniform"/>
        </Style>

        <Style x:Key="LineButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource Perelegans.ForegroundBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Perelegans.MenuHoverBrush}"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource Perelegans.BorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Perelegans.StatsChartMetricBackground}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentLineButtonStyle" TargetType="Button" BasedOn="{StaticResource LineButtonStyle}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Perelegans.AccentBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource Perelegans.AccentBrush}"/>
        </Style>

        <Style x:Key="IconButtonStyle" TargetType="Button" BasedOn="{StaticResource LineButtonStyle}">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="PresetButtonStyle" TargetType="Button" BasedOn="{StaticResource LineButtonStyle}">
            <Setter Property="Height" Value="30"/>
            <Setter Property="MinWidth" Value="76"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Perelegans.BorderBrush}"/>
        </Style>

        <Style x:Key="HeroComposerStyle" TargetType="Border">
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="IsHitTestVisible" Value="True"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="0"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasConversationStarted}" Value="True">
                    <Setter Property="IsHitTestVisible" Value="False"/>
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 To="0"
                                                 Duration="0:0:0.22"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                 To="-28"
                                                 Duration="0:0:0.22">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BottomComposerStyle" TargetType="Border">
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="18"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasConversationStarted}" Value="True">
                    <Setter Property="IsHitTestVisible" Value="True"/>
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 To="1"
                                                 Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                 To="0"
                                                 Duration="0:0:0.2">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ConversationScrollStyle" TargetType="ScrollViewer">
            <Setter Property="Opacity" Value="0"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasConversationStarted}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 To="1"
                                                 Duration="0:0:0.24"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </mah:MetroWindow.Resources>

    <Grid Opacity="0">
        <Grid.Triggers>
            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                         From="0"
                                         To="1"
                                         Duration="0:0:0.18"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Grid.Triggers>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="228"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Padding="16"
                Background="{DynamicResource Perelegans.PanelBackground}"
                BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="{i18n:Translate Main_AppTitle}"
                               FontSize="19"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding MonitoringStateText}"
                               Margin="0,6,0,0"
                               Style="{StaticResource QuietTextStyle}"/>
                </StackPanel>

                <Border Grid.Row="1"
                        Margin="0,26,0,0"
                        Padding="0,0,0,18"
                        BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                        BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="{i18n:Translate Main_CurrentApp}"
                                   Style="{StaticResource QuietTextStyle}"/>
                        <TextBlock Text="{Binding CurrentProcessName}"
                                   Margin="0,4,0,0"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding CurrentProcessDurationText}"
                                   Margin="0,3,0,0"
                                   Style="{StaticResource QuietTextStyle}"/>

                        <TextBlock Text="{i18n:Translate Main_Total}"
                                   Margin="0,22,0,0"
                                   Style="{StaticResource QuietTextStyle}"/>
                        <TextBlock Text="{Binding TotalDurationText}"
                                   Margin="0,4,0,0"
                                   FontSize="15"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding ApplicationCountText}"
                                   Margin="0,3,0,0"
                                   Style="{StaticResource QuietTextStyle}"/>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="3">
                    <Button Command="{Binding ToggleMonitorCommand}"
                            Style="{StaticResource AccentLineButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="21" Height="16" Margin="0,0,10,0">
                                <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}">
                                    <Path.Style>
                                        <Style TargetType="Path" BasedOn="{StaticResource LineIconPathStyle}">
                                            <Setter Property="Data" Value="{StaticResource Icon.Pause}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMonitorEnabled}" Value="False">
                                                    <Setter Property="Data" Value="{StaticResource Icon.Play}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                            </Viewbox>
                            <TextBlock Text="{Binding MonitorButtonText}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ToggleFocusModeCommand}"
                            Style="{StaticResource LineButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="21" Height="16" Margin="0,0,10,0">
                                <Path Style="{StaticResource LineIconPathStyle}"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Data="{StaticResource Icon.Target}"/>
                            </Viewbox>
                            <TextBlock Text="{Binding FocusModeButtonText}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding RefreshCommand}"
                            Style="{StaticResource LineButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="21" Height="16" Margin="0,0,10,0">
                                <Path Style="{StaticResource LineIconPathStyle}"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Data="{StaticResource Icon.RefreshCw}"/>
                            </Viewbox>
                            <TextBlock Text="{i18n:Translate Main_Refresh}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ToggleGalaxyCommand}"
                            Style="{StaticResource LineButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="21" Height="16" Margin="0,0,10,0">
                                <Path Style="{StaticResource LineIconPathStyle}"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Data="{StaticResource Icon.Sparkles}"/>
                            </Viewbox>
                            <TextBlock Text="{i18n:Translate Main_Galaxy}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ToggleStatisticsCommand}"
                            Style="{StaticResource LineButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="21" Height="16" Margin="0,0,10,0">
                                <Path Style="{StaticResource LineIconPathStyle}"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Data="{StaticResource Icon.PieChart}"/>
                            </Viewbox>
                            <TextBlock Text="{i18n:Translate Main_Statistics}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding GenerateDailyReviewCommand}"
                            Style="{StaticResource LineButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="21" Height="16" Margin="0,0,10,0">
                                <Path Style="{StaticResource LineIconPathStyle}"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Data="{StaticResource Icon.ListChecks}"/>
                            </Viewbox>
                            <TextBlock Text="{i18n:Translate Main_DailyReview}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ToggleCompanionRoomCommand}"
                            Style="{StaticResource LineButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="21" Height="16" Margin="0,0,10,0">
                                <Path Style="{StaticResource LineIconPathStyle}"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Data="{StaticResource Icon.BrainCircuit}"/>
                            </Viewbox>
                            <TextBlock Text="伙伴档案" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ClearUsageDataCommand}"
                            Style="{StaticResource LineButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="21" Height="16" Margin="0,0,10,0">
                                <Path Style="{StaticResource LineIconPathStyle}"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Data="{StaticResource Icon.Trash2}"/>
                            </Viewbox>
                            <TextBlock Text="{i18n:Translate Main_ClearData}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ExitAppCommand}"
                            Style="{StaticResource LineButtonStyle}"
                            Margin="0">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="21" Height="16" Margin="0,0,10,0">
                                <Path Style="{StaticResource LineIconPathStyle}"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Data="{StaticResource Icon.X}"/>
                            </Viewbox>
                            <TextBlock Text="{i18n:Translate Main_Exit}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" MouseLeftButtonDown="MainSurface_MouseLeftButtonDown">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="28,20,28,0">
                <Button DockPanel.Dock="Right"
                        Command="{Binding OpenSettingsCommand}"
                        Style="{StaticResource IconButtonStyle}">
                    <Viewbox Width="17" Height="17">
                        <Path Style="{StaticResource LineIconPathStyle}"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="{StaticResource Icon.Settings}"/>
                    </Viewbox>
                </Button>
                <TextBlock DockPanel.Dock="Right"
                           Margin="0,9,0,0"
                           Text="{Binding ProductiveShareText}"
                           Style="{StaticResource QuietTextStyle}"/>
                <StackPanel>
                    <TextBlock Text="{Binding CurrentFocusGoalDisplay}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding FocusModeStatusText}"
                               Margin="0,4,0,0"
                               Style="{StaticResource QuietTextStyle}"/>
                    <TextBlock Text="{Binding MemoryCountText}"
                               Margin="0,4,0,0"
                               Style="{StaticResource QuietTextStyle}"/>
                </StackPanel>
            </DockPanel>

            <ScrollViewer x:Name="ConversationScrollViewer"
                          Grid.Row="1"
                          Margin="28,20,28,10"
                          Padding="0,18,0,18"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Style="{StaticResource ConversationScrollStyle}">
                <StackPanel>
                    <ItemsControl ItemsSource="{Binding ConversationMessages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,12">
                                    <Border x:Name="Bubble"
                                            MaxWidth="620"
                                            Padding="13,10"
                                            CornerRadius="0"
                                            HorizontalAlignment="{Binding Alignment}"
                                            Background="{DynamicResource Perelegans.PanelBackground}"
                                            BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock x:Name="BubbleText"
                                                       MinHeight="18"
                                                       Text="{Binding Text}"
                                                       FontSize="14"
                                                       LineHeight="22"
                                                       TextWrapping="Wrap"
                                                       Foreground="{DynamicResource Perelegans.ForegroundBrush}"/>
                                             <StackPanel Orientation="Horizontal"
                                                         HorizontalAlignment="Right"
                                                         Margin="0,8,0,0">
                                                <Button Width="26"
                                                        Height="26"
                                                        Command="{Binding DataContext.RewindConversationToCommand, RelativeSource={RelativeSource AncestorType=mah:MetroWindow}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource IconButtonStyle}"
                                                        ToolTip="{i18n:Translate Main_ChatRewind}"
                                                        Margin="0,0,4,0">
                                                    <Viewbox Width="12"
                                                             Height="12">
                                                        <Path Data="M 12,5 L 6,11 L 12,17 M 7,11 H 15 C 20,11 20,19 15,19 H 10"
                                                              Stroke="{DynamicResource Perelegans.SubtleForegroundBrush}"
                                                              Style="{StaticResource LineIconPathStyle}"/>
                                                    </Viewbox>
                                                </Button>
                                                <Button Width="26"
                                                        Height="26"
                                                        Command="{Binding DataContext.DeleteConversationMessageCommand, RelativeSource={RelativeSource AncestorType=mah:MetroWindow}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource IconButtonStyle}"
                                                        ToolTip="{i18n:Translate Main_ChatDelete}"
                                                        Margin="0,0,4,0">
                                                    <Viewbox Width="11"
                                                             Height="11">
                                                        <Path Data="M 6,6 L 18,18 M 18,6 L 6,18"
                                                              Stroke="{DynamicResource Perelegans.SubtleForegroundBrush}"
                                                              Style="{StaticResource LineIconPathStyle}"/>
                                                    </Viewbox>
                                                </Button>
                                                  <Button Content="{i18n:Translate Main_ChatStop}"
                                                          Command="{Binding DataContext.StopAssistantOutputCommand, RelativeSource={RelativeSource AncestorType=mah:MetroWindow}}"
                                                          Margin="0">
                                                      <Button.Style>
                                                          <Style TargetType="Button" BasedOn="{StaticResource PresetButtonStyle}">
                                                              <Setter Property="Visibility" Value="Collapsed"/>
                                                              <Style.Triggers>
                                                                  <DataTrigger Binding="{Binding IsStreaming}" Value="True">
                                                                      <Setter Property="Visibility" Value="Visible"/>
                                                                  </DataTrigger>
                                                                  <DataTrigger Binding="{Binding IsInterruptible}" Value="True">
                                                                      <Setter Property="Visibility" Value="Visible"/>
                                                                  </DataTrigger>
                                                              </Style.Triggers>
                                                          </Style>
                                                      </Button.Style>
                                                  </Button>
                                              </StackPanel>
                                              <Border Margin="0,14,0,0"
                                                      Padding="14"
                                                      Background="{DynamicResource Perelegans.WindowBackground}"
                                                      BorderBrush="{DynamicResource Perelegans.AccentBrush}"
                                                      BorderThickness="1"
                                                      Visibility="{Binding HasDailyReviewCard, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                  <StackPanel>
                                                      <DockPanel Margin="0,0,0,12">
                                                          <StackPanel DockPanel.Dock="Left">
                                                              <TextBlock Text="{Binding DailyReviewCard.Title}"
                                                                         FontSize="15"
                                                                         FontWeight="SemiBold"/>
                                                              <TextBlock Text="{Binding DailyReviewCard.Subtitle}"
                                                                         Margin="0,3,0,0"
                                                                         FontSize="11"
                                                                         Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                                                          </StackPanel>
                                                          <ItemsControl ItemsSource="{Binding DailyReviewCard.Metrics}"
                                                                        HorizontalAlignment="Right">
                                                              <ItemsControl.ItemsPanel>
                                                                  <ItemsPanelTemplate>
                                                                      <WrapPanel Orientation="Horizontal"/>
                                                                  </ItemsPanelTemplate>
                                                              </ItemsControl.ItemsPanel>
                                                              <ItemsControl.ItemTemplate>
                                                                  <DataTemplate>
                                                                      <Border MinWidth="58"
                                                                              Padding="8,5"
                                                                              Margin="6,0,0,6"
                                                                              Background="{DynamicResource Perelegans.StatsChartHighlightBackground}"
                                                                              BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                                                                              BorderThickness="1">
                                                                          <StackPanel>
                                                                              <TextBlock Text="{Binding Value}"
                                                                                         FontSize="13"
                                                                                         FontWeight="SemiBold"
                                                                                         HorizontalAlignment="Center"
                                                                                         Foreground="#FFFF8FC3"/>
                                                                              <TextBlock Text="{Binding Caption}"
                                                                                         Margin="0,2,0,0"
                                                                                         MaxWidth="92"
                                                                                         FontSize="10"
                                                                                         TextAlignment="Center"
                                                                                         TextTrimming="CharacterEllipsis"
                                                                                         Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                                                                          </StackPanel>
                                                                      </Border>
                                                                  </DataTemplate>
                                                              </ItemsControl.ItemTemplate>
                                                          </ItemsControl>
                                                      </DockPanel>

                                                      <Border Padding="10,8"
                                                              Margin="0,0,0,10"
                                                              Background="{DynamicResource Perelegans.StatsChartHighlightBackground}"
                                                              BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                                                              BorderThickness="1">
                                                          <StackPanel>
                                                              <TextBlock Text="{Binding DailyReviewCard.EncouragementTitle}"
                                                                         FontSize="11"
                                                                         FontWeight="SemiBold"
                                                                         Foreground="#FFFF8FC3"/>
                                                              <TextBlock Text="{Binding DailyReviewCard.Encouragement}"
                                                                         Margin="0,5,0,0"
                                                                         FontSize="12"
                                                                         LineHeight="18"
                                                                         TextWrapping="Wrap"/>
                                                          </StackPanel>
                                                      </Border>

                                                      <TextBlock Text="{Binding DailyReviewCard.OverviewTitle}"
                                                                 FontSize="11"
                                                                 FontWeight="SemiBold"
                                                                 Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                                                      <TextBlock Text="{Binding DailyReviewCard.Overview}"
                                                                 Margin="0,4,0,12"
                                                                 FontSize="12"
                                                                 LineHeight="18"
                                                                 TextWrapping="Wrap"/>

                                                      <Grid>
                                                          <Grid.ColumnDefinitions>
                                                              <ColumnDefinition Width="*"/>
                                                              <ColumnDefinition Width="12"/>
                                                              <ColumnDefinition Width="*"/>
                                                          </Grid.ColumnDefinitions>
                                                          <StackPanel Grid.Column="0">
                                                              <TextBlock Text="{Binding DailyReviewCard.HighlightsTitle}"
                                                                         Margin="0,0,0,5"
                                                                         FontSize="11"
                                                                         FontWeight="SemiBold"
                                                                         Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                                                              <ItemsControl ItemsSource="{Binding DailyReviewCard.Highlights}">
                                                                  <ItemsControl.ItemTemplate>
                                                                      <DataTemplate>
                                                                          <TextBlock Text="{Binding}"
                                                                                     Margin="0,0,0,5"
                                                                                     FontSize="12"
                                                                                     LineHeight="17"
                                                                                     TextWrapping="Wrap"/>
                                                                      </DataTemplate>
                                                                  </ItemsControl.ItemTemplate>
                                                              </ItemsControl>
                                                          </StackPanel>
                                                          <StackPanel Grid.Column="2">
                                                              <TextBlock Text="{Binding DailyReviewCard.RisksTitle}"
                                                                         Margin="0,0,0,5"
                                                                         FontSize="11"
                                                                         FontWeight="SemiBold"
                                                                         Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                                                              <ItemsControl ItemsSource="{Binding DailyReviewCard.Risks}">
                                                                  <ItemsControl.ItemTemplate>
                                                                      <DataTemplate>
                                                                          <TextBlock Text="{Binding}"
                                                                                     Margin="0,0,0,5"
                                                                                     FontSize="12"
                                                                                     LineHeight="17"
                                                                                     TextWrapping="Wrap"/>
                                                                      </DataTemplate>
                                                                  </ItemsControl.ItemTemplate>
                                                              </ItemsControl>
                                                          </StackPanel>
                                                      </Grid>

                                                       <Border Padding="10,8"
                                                               Margin="0,9,0,0"
                                                               Background="{DynamicResource Perelegans.PanelBackground}"
                                                               BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                                                              BorderThickness="1"
                                                              Visibility="{Binding DailyReviewCard.HasNextAction, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                          <StackPanel>
                                                              <TextBlock Text="{Binding DailyReviewCard.NextActionTitle}"
                                                                         FontSize="11"
                                                                         FontWeight="SemiBold"
                                                                         Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                                                               <TextBlock Text="{Binding DailyReviewCard.NextAction}"
                                                                          Margin="0,5,0,0"
                                                                          FontSize="12"
                                                                          LineHeight="18"
                                                                          TextWrapping="Wrap"/>
                                                           </StackPanel>
                                                       </Border>
                                                       <Border Padding="10,8"
                                                               Margin="0,9,0,0"
                                                               Background="{DynamicResource Perelegans.StatsChartHighlightBackground}"
                                                               BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                                                               BorderThickness="1"
                                                               Visibility="{Binding DailyReviewCard.HasTaskDebtItems, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                           <StackPanel>
                                                               <TextBlock Text="任务债务雷达"
                                                                          FontSize="11"
                                                                          FontWeight="SemiBold"
                                                                          Foreground="#FFFF8FC3"/>
