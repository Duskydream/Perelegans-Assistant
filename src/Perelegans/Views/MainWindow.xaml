<mah:MetroWindow x:Class="Perelegans.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:i18n="clr-namespace:Perelegans.i18n"
        Title="{i18n:Translate Main_WindowTitle}"
        TitleCharacterCasing="Normal"
        Width="1040"
        Height="720"
        MinWidth="820"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        ShowTitleBar="True"
        TitleBarHeight="32"
        BorderThickness="1"
        WindowTitleBrush="{DynamicResource Perelegans.PanelBackground}"
        NonActiveWindowTitleBrush="{DynamicResource Perelegans.PanelBackground}"
        GlowBrush="{DynamicResource Perelegans.BorderBrush}"
        Background="{DynamicResource Perelegans.WindowBackground}"
        Foreground="{DynamicResource Perelegans.ForegroundBrush}">

    <mah:MetroWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style x:Key="QuietTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="IconGlyphStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Width" Value="22"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource Perelegans.ForegroundBrush}"/>
        </Style>

        <Style x:Key="LineButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource Perelegans.ForegroundBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Perelegans.MenuHoverBrush}"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource Perelegans.BorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Perelegans.StatsChartMetricBackground}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentLineButtonStyle" TargetType="Button" BasedOn="{StaticResource LineButtonStyle}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Perelegans.AccentBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource Perelegans.AccentBrush}"/>
        </Style>

        <Style x:Key="IconButtonStyle" TargetType="Button" BasedOn="{StaticResource LineButtonStyle}">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="PresetButtonStyle" TargetType="Button" BasedOn="{StaticResource LineButtonStyle}">
            <Setter Property="Height" Value="30"/>
            <Setter Property="MinWidth" Value="76"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Perelegans.BorderBrush}"/>
        </Style>

        <Style x:Key="HeroComposerStyle" TargetType="Border">
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="IsHitTestVisible" Value="True"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="0"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasConversationStarted}" Value="True">
                    <Setter Property="IsHitTestVisible" Value="False"/>
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 To="0"
                                                 Duration="0:0:0.22"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                 To="-28"
                                                 Duration="0:0:0.22">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BottomComposerStyle" TargetType="Border">
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="18"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasConversationStarted}" Value="True">
                    <Setter Property="IsHitTestVisible" Value="True"/>
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 To="1"
                                                 Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                 To="0"
                                                 Duration="0:0:0.2">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ConversationScrollStyle" TargetType="ScrollViewer">
            <Setter Property="Opacity" Value="0"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasConversationStarted}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 To="1"
                                                 Duration="0:0:0.24"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </mah:MetroWindow.Resources>

    <Grid Opacity="0">
        <Grid.Triggers>
            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                         From="0"
                                         To="1"
                                         Duration="0:0:0.18"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Grid.Triggers>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="228"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Padding="16"
                Background="{DynamicResource Perelegans.PanelBackground}"
                BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="{i18n:Translate Main_AppTitle}"
                               FontSize="19"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding MonitoringStateText}"
                               Margin="0,6,0,0"
                               Style="{StaticResource QuietTextStyle}"/>
                </StackPanel>

                <Border Grid.Row="1"
                        Margin="0,26,0,0"
                        Padding="0,0,0,18"
                        BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                        BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="{i18n:Translate Main_CurrentApp}"
                                   Style="{StaticResource QuietTextStyle}"/>
                        <TextBlock Text="{Binding CurrentProcessName}"
                                   Margin="0,4,0,0"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding CurrentProcessDurationText}"
                                   Margin="0,3,0,0"
                                   Style="{StaticResource QuietTextStyle}"/>

                        <TextBlock Text="{i18n:Translate Main_Total}"
                                   Margin="0,22,0,0"
                                   Style="{StaticResource QuietTextStyle}"/>
                        <TextBlock Text="{Binding TotalDurationText}"
                                   Margin="0,4,0,0"
                                   FontSize="15"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding ApplicationCountText}"
                                   Margin="0,3,0,0"
                                   Style="{StaticResource QuietTextStyle}"/>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="3">
                    <Button Command="{Binding ToggleMonitorCommand}"
                            Style="{StaticResource AccentLineButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE769;" Style="{StaticResource IconGlyphStyle}"/>
                            <TextBlock Text="{Binding MonitorButtonText}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding RefreshCommand}"
                            Style="{StaticResource LineButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;" Style="{StaticResource IconGlyphStyle}"/>
                            <TextBlock Text="{i18n:Translate Main_Refresh}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ToggleGalaxyCommand}"
                            Style="{StaticResource LineButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE735;" Style="{StaticResource IconGlyphStyle}"/>
                            <TextBlock Text="{i18n:Translate Main_Galaxy}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ClearUsageDataCommand}"
                            Style="{StaticResource LineButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74D;" Style="{StaticResource IconGlyphStyle}"/>
                            <TextBlock Text="{i18n:Translate Main_ClearData}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ExitAppCommand}"
                            Style="{StaticResource LineButtonStyle}"
                            Margin="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8BB;" Style="{StaticResource IconGlyphStyle}"/>
                            <TextBlock Text="{i18n:Translate Main_Exit}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" MouseLeftButtonDown="MainSurface_MouseLeftButtonDown">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="28,20,28,0">
                <Button DockPanel.Dock="Right"
                        Command="{Binding OpenSettingsCommand}"
                        Style="{StaticResource IconButtonStyle}">
                    <TextBlock Text="&#xE713;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="15"
                               Foreground="{DynamicResource Perelegans.ForegroundBrush}"/>
                </Button>
                <TextBlock DockPanel.Dock="Right"
                           Margin="0,9,0,0"
                           Text="{Binding ProductiveShareText}"
                           Style="{StaticResource QuietTextStyle}"/>
                <StackPanel>
                    <TextBlock Text="{Binding CurrentFocusGoalDisplay}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding FocusTaskCountText}"
                               Margin="0,4,0,0"
                               Style="{StaticResource QuietTextStyle}"/>
                </StackPanel>
            </DockPanel>

            <ScrollViewer x:Name="ConversationScrollViewer"
                          Grid.Row="1"
                          Margin="28,20,28,10"
                          Padding="0,18,0,18"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Style="{StaticResource ConversationScrollStyle}">
                <ItemsControl ItemsSource="{Binding ConversationMessages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,12">
                                <Border x:Name="Bubble"
                                        MaxWidth="560"
                                        Padding="13,10"
                                        CornerRadius="0"
                                        HorizontalAlignment="{Binding Alignment}"
                                        Background="{DynamicResource Perelegans.PanelBackground}"
                                        BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                                        BorderThickness="1">
                                    <TextBlock x:Name="BubbleText"
                                               MinHeight="18"
                                               Text="{Binding Text}"
                                               FontSize="14"
                                               LineHeight="22"
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource Perelegans.ForegroundBrush}"/>
                                </Border>
                            </Grid>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsUser}" Value="True">
                                    <Setter TargetName="Bubble" Property="Background" Value="{DynamicResource Perelegans.StatsChartHighlightBackground}"/>
                                    <Setter TargetName="Bubble" Property="BorderBrush" Value="{DynamicResource Perelegans.AccentBrush}"/>
                                    <Setter TargetName="BubbleText" Property="Foreground" Value="{DynamicResource Perelegans.ForegroundBrush}"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Border Grid.Row="2"
                    Margin="28,0,28,16"
                    Padding="10"
                    CornerRadius="0"
                    Background="{DynamicResource Perelegans.PanelBackground}"
                    BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                    BorderThickness="1"
                    Style="{StaticResource BottomComposerStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             Height="36"
                             Padding="4,0"
                             BorderThickness="0"
                             Background="Transparent"
                             VerticalContentAlignment="Center"
                             FontSize="14"
                             Text="{Binding ConversationInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             mah:TextBoxHelper.Watermark="{i18n:Translate Main_InputWatermark}">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding SendConversationMessageCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>

                    <Button Grid.Column="2"
                            Content="{i18n:Translate Main_Send}"
                            Width="76"
                            Height="34"
                            HorizontalContentAlignment="Center"
                            Command="{Binding SendConversationMessageCommand}"
                            Style="{StaticResource AccentLineButtonStyle}"/>
                </Grid>
            </Border>

            <DockPanel Grid.Row="3" Margin="28,0,28,18">
                <TextBlock Text="{Binding StatusText}"
                           Style="{StaticResource QuietTextStyle}"/>
            </DockPanel>

            <Border Grid.Row="1"
                    Grid.RowSpan="2"
                    Width="640"
                    Padding="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="Transparent"
                    Style="{StaticResource HeroComposerStyle}">
                <StackPanel>
                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,28">
                        <TextBlock Text="{i18n:Translate Main_PrimaryPrompt}"
                                   FontSize="34"
                                   FontWeight="SemiBold"
                                   TextAlignment="Center"/>
                        <TextBlock Text="{Binding CurrentFocusGoalDisplay}"
                                   Margin="0,8,0,0"
                                   FontSize="13"
                                   TextAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                    </StackPanel>

                    <Border CornerRadius="0"
                            Padding="16,14"
                            Background="{DynamicResource Perelegans.PanelBackground}"
                            BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBox Grid.Row="0"
                                     MinHeight="74"
                                     FontSize="15"
                                     Padding="0"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="False"
                                     VerticalContentAlignment="Top"
                                     Text="{Binding ConversationInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     mah:TextBoxHelper.Watermark="{i18n:Translate Main_InputWatermark}">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter" Command="{Binding SendConversationMessageCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>

                            <DockPanel Grid.Row="2" LastChildFill="False">
                                <WrapPanel DockPanel.Dock="Left">
                                    <Button Content="{i18n:Translate Main_PresetDeepWork}"
                                            Command="{Binding UseGoalPresetCommand}"
                                            CommandParameter="{i18n:Translate Main_PresetDeepWorkPrompt}"
                                            Style="{StaticResource PresetButtonStyle}"/>
                                    <Button Content="{i18n:Translate Main_PresetStudy}"
                                            Command="{Binding UseGoalPresetCommand}"
                                            CommandParameter="{i18n:Translate Main_PresetStudyPrompt}"
                                            Style="{StaticResource PresetButtonStyle}"/>
                                    <Button Content="{i18n:Translate Main_PresetWriting}"
                                            Command="{Binding UseGoalPresetCommand}"
                                            CommandParameter="{i18n:Translate Main_PresetWritingPrompt}"
                                            Style="{StaticResource PresetButtonStyle}"/>
                                    <Button Content="{i18n:Translate Main_PresetCoding}"
                                            Command="{Binding UseGoalPresetCommand}"
                                            CommandParameter="{i18n:Translate Main_PresetCodingPrompt}"
                                            Style="{StaticResource PresetButtonStyle}"/>
                                </WrapPanel>

                                <Button Content="{i18n:Translate Main_Send}"
                                        Width="76"
                                        Height="30"
                                        HorizontalContentAlignment="Center"
                                        Command="{Binding SendConversationMessageCommand}"
                                        Style="{StaticResource AccentLineButtonStyle}"/>
                            </DockPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.RowSpan="4"
                    Margin="24"
                    Padding="18"
                    CornerRadius="0"
                    Background="{DynamicResource Perelegans.WindowBackground}"
                    BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                    BorderThickness="1"
                    Visibility="{Binding IsGalaxyVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,12">
                        <Button DockPanel.Dock="Right"
                                Content="{i18n:Translate Main_CloseGalaxy}"
                                Command="{Binding ToggleGalaxyCommand}"
                                Style="{StaticResource PresetButtonStyle}"
                                Margin="0"/>
                        <StackPanel>
                            <TextBlock Text="{i18n:Translate Main_GalaxyTitle}"
                                       FontSize="22"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding FocusTaskCountText}"
                                       Margin="0,4,0,0"
                                       Style="{StaticResource QuietTextStyle}"/>
                        </StackPanel>
                    </DockPanel>

                    <ScrollViewer Grid.Row="1"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  PreviewMouseWheel="GalaxyScrollViewer_PreviewMouseWheel">
                        <Grid Width="920" Height="640" ClipToBounds="True">
                            <Grid.RenderTransform>
                                <ScaleTransform x:Name="GalaxyScaleTransform" ScaleX="1" ScaleY="1"/>
                            </Grid.RenderTransform>

                            <ItemsControl ItemsSource="{Binding GalaxyLinks}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas Width="920" Height="640"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Line X1="{Binding X1}"
                                              Y1="{Binding Y1}"
                                              X2="{Binding X2}"
                                              Y2="{Binding Y2}"
                                              Stroke="{DynamicResource Perelegans.AccentBrush}"
                                              StrokeThickness="1.2"
                                              Opacity="{Binding Opacity}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <ItemsControl ItemsSource="{Binding FocusTasks}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas Width="920" Height="640"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                        <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Width="160">
                                            <Ellipse Width="{Binding NodeSize}"
                                                     Height="{Binding NodeSize}"
                                                     Fill="{DynamicResource Perelegans.AccentBrush}">
                                                <Ellipse.Effect>
                                                    <DropShadowEffect BlurRadius="14"
                                                                      ShadowDepth="0"
                                                                      Opacity="0.45"
                                                                      Color="#DFA8B5"/>
                                                </Ellipse.Effect>
                                            </Ellipse>
                                            <TextBlock Text="{Binding QuestTitle}"
                                                       Margin="0,6,0,0"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Title}"
                                                       Margin="0,2,0,0"
                                                       FontSize="11"
                                                       TextWrapping="Wrap"
                                                       Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</mah:MetroWindow>
