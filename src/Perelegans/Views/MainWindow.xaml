<mah:MetroWindow x:Class="Perelegans.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:i18n="clr-namespace:Perelegans.i18n"
        xmlns:models="clr-namespace:Perelegans.Models"
        Title="{i18n:Translate Main_WindowTitle}"
        TitleCharacterCasing="Normal"
        Width="1040"
        Height="720"
        MinWidth="820"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        ShowTitleBar="True"
        TitleBarHeight="32"
        BorderThickness="1"
        WindowTitleBrush="{DynamicResource Perelegans.PanelBackground}"
        NonActiveWindowTitleBrush="{DynamicResource Perelegans.PanelBackground}"
        GlowBrush="{DynamicResource Perelegans.BorderBrush}"
        Background="{DynamicResource Perelegans.WindowBackground}"
        Foreground="{DynamicResource Perelegans.ForegroundBrush}">

    <mah:MetroWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style x:Key="QuietTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="LineIconPathStyle" TargetType="Path">
            <Setter Property="Fill" Value="Transparent"/>
            <Setter Property="StrokeThickness" Value="1.45"/>
            <Setter Property="StrokeStartLineCap" Value="Round"/>
            <Setter Property="StrokeEndLineCap" Value="Round"/>
            <Setter Property="StrokeLineJoin" Value="Round"/>
            <Setter Property="Stretch" Value="Uniform"/>
        </Style>

        <Style x:Key="LineButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource Perelegans.ForegroundBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Perelegans.MenuHoverBrush}"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource Perelegans.BorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Perelegans.StatsChartMetricBackground}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentLineButtonStyle" TargetType="Button" BasedOn="{StaticResource LineButtonStyle}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Perelegans.AccentBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource Perelegans.AccentBrush}"/>
        </Style>

        <Style x:Key="IconButtonStyle" TargetType="Button" BasedOn="{StaticResource LineButtonStyle}">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="PresetButtonStyle" TargetType="Button" BasedOn="{StaticResource LineButtonStyle}">
            <Setter Property="Height" Value="30"/>
            <Setter Property="MinWidth" Value="76"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Perelegans.BorderBrush}"/>
        </Style>

        <Style x:Key="HeroComposerStyle" TargetType="Border">
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="IsHitTestVisible" Value="True"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="0"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasConversationStarted}" Value="True">
                    <Setter Property="IsHitTestVisible" Value="False"/>
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 To="0"
                                                 Duration="0:0:0.22"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                 To="-28"
                                                 Duration="0:0:0.22">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BottomComposerStyle" TargetType="Border">
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="18"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasConversationStarted}" Value="True">
                    <Setter Property="IsHitTestVisible" Value="True"/>
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 To="1"
                                                 Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                 To="0"
                                                 Duration="0:0:0.2">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ConversationScrollStyle" TargetType="ScrollViewer">
            <Setter Property="Opacity" Value="0"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasConversationStarted}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 To="1"
                                                 Duration="0:0:0.24"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </mah:MetroWindow.Resources>

    <Grid Opacity="0">
        <Grid.Triggers>
            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                         From="0"
                                         To="1"
                                         Duration="0:0:0.18"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Grid.Triggers>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="228"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Padding="16"
                Background="{DynamicResource Perelegans.PanelBackground}"
                BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="{i18n:Translate Main_AppTitle}"
                               FontSize="19"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding MonitoringStateText}"
                               Margin="0,6,0,0"
                               Style="{StaticResource QuietTextStyle}"/>
                </StackPanel>

                <Border Grid.Row="1"
                        Margin="0,26,0,0"
                        Padding="0,0,0,18"
                        BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                        BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="{i18n:Translate Main_CurrentApp}"
                                   Style="{StaticResource QuietTextStyle}"/>
                        <TextBlock Text="{Binding CurrentProcessName}"
                                   Margin="0,4,0,0"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding CurrentProcessDurationText}"
                                   Margin="0,3,0,0"
                                   Style="{StaticResource QuietTextStyle}"/>

                        <TextBlock Text="{i18n:Translate Main_Total}"
                                   Margin="0,22,0,0"
                                   Style="{StaticResource QuietTextStyle}"/>
                        <TextBlock Text="{Binding TotalDurationText}"
                                   Margin="0,4,0,0"
                                   FontSize="15"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding ApplicationCountText}"
                                   Margin="0,3,0,0"
                                   Style="{StaticResource QuietTextStyle}"/>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="3">
                    <Button Command="{Binding ToggleMonitorCommand}"
                            Style="{StaticResource AccentLineButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="21" Height="16" Margin="0,0,10,0">
                                <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}">
                                    <Path.Style>
                                        <Style TargetType="Path" BasedOn="{StaticResource LineIconPathStyle}">
                                            <Setter Property="Data" Value="{StaticResource Icon.Pause}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMonitorEnabled}" Value="False">
                                                    <Setter Property="Data" Value="{StaticResource Icon.Play}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                            </Viewbox>
                            <TextBlock Text="{Binding MonitorButtonText}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ToggleFocusModeCommand}"
                            Style="{StaticResource LineButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="21" Height="16" Margin="0,0,10,0">
                                <Path Style="{StaticResource LineIconPathStyle}"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Data="{StaticResource Icon.Target}"/>
                            </Viewbox>
                            <TextBlock Text="{Binding FocusModeButtonText}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding RefreshCommand}"
                            Style="{StaticResource LineButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="21" Height="16" Margin="0,0,10,0">
                                <Path Style="{StaticResource LineIconPathStyle}"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Data="{StaticResource Icon.RefreshCw}"/>
                            </Viewbox>
                            <TextBlock Text="{i18n:Translate Main_Refresh}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ToggleGalaxyCommand}"
                            Style="{StaticResource LineButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="21" Height="16" Margin="0,0,10,0">
                                <Path Style="{StaticResource LineIconPathStyle}"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Data="{StaticResource Icon.Sparkles}"/>
                            </Viewbox>
                            <TextBlock Text="{i18n:Translate Main_Galaxy}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ToggleStatisticsCommand}"
                            Style="{StaticResource LineButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="21" Height="16" Margin="0,0,10,0">
                                <Path Style="{StaticResource LineIconPathStyle}"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Data="{StaticResource Icon.PieChart}"/>
                            </Viewbox>
                            <TextBlock Text="{i18n:Translate Main_Statistics}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding GenerateDailyReviewCommand}"
                            Style="{StaticResource LineButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="21" Height="16" Margin="0,0,10,0">
                                <Path Style="{StaticResource LineIconPathStyle}"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Data="{StaticResource Icon.ListChecks}"/>
                            </Viewbox>
                            <TextBlock Text="{i18n:Translate Main_DailyReview}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ClearUsageDataCommand}"
                            Style="{StaticResource LineButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="21" Height="16" Margin="0,0,10,0">
                                <Path Style="{StaticResource LineIconPathStyle}"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Data="{StaticResource Icon.Trash2}"/>
                            </Viewbox>
                            <TextBlock Text="{i18n:Translate Main_ClearData}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ExitAppCommand}"
                            Style="{StaticResource LineButtonStyle}"
                            Margin="0">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="21" Height="16" Margin="0,0,10,0">
                                <Path Style="{StaticResource LineIconPathStyle}"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Data="{StaticResource Icon.X}"/>
                            </Viewbox>
                            <TextBlock Text="{i18n:Translate Main_Exit}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" MouseLeftButtonDown="MainSurface_MouseLeftButtonDown">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="28,20,28,0">
                <Button DockPanel.Dock="Right"
                        Command="{Binding OpenSettingsCommand}"
                        Style="{StaticResource IconButtonStyle}">
                    <Viewbox Width="17" Height="17">
                        <Path Style="{StaticResource LineIconPathStyle}"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="{StaticResource Icon.Settings}"/>
                    </Viewbox>
                </Button>
                <TextBlock DockPanel.Dock="Right"
                           Margin="0,9,0,0"
                           Text="{Binding ProductiveShareText}"
                           Style="{StaticResource QuietTextStyle}"/>
                <StackPanel>
                    <TextBlock Text="{Binding CurrentFocusGoalDisplay}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding FocusModeStatusText}"
                               Margin="0,4,0,0"
                               Style="{StaticResource QuietTextStyle}"/>
                    <TextBlock Text="{Binding MemoryCountText}"
                               Margin="0,4,0,0"
                               Style="{StaticResource QuietTextStyle}"/>
                </StackPanel>
            </DockPanel>

            <ScrollViewer x:Name="ConversationScrollViewer"
                          Grid.Row="1"
                          Margin="28,20,28,10"
                          Padding="0,18,0,18"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Style="{StaticResource ConversationScrollStyle}">
                <StackPanel>
                    <ItemsControl ItemsSource="{Binding ConversationMessages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,12">
                                    <Border x:Name="Bubble"
                                            MaxWidth="620"
                                            Padding="13,10"
                                            CornerRadius="0"
                                            HorizontalAlignment="{Binding Alignment}"
                                            Background="{DynamicResource Perelegans.PanelBackground}"
                                            BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock x:Name="BubbleText"
                                                       MinHeight="18"
                                                       Text="{Binding Text}"
                                                       FontSize="14"
                                                       LineHeight="22"
                                                       TextWrapping="Wrap"
                                                       Foreground="{DynamicResource Perelegans.ForegroundBrush}"/>
                                            <StackPanel Orientation="Horizontal"
                                                        HorizontalAlignment="Right"
                                                        Margin="0,8,0,0">
                                                <Button Width="30"
                                                        Height="30"
                                                        Command="{Binding DataContext.RewindConversationToCommand, RelativeSource={RelativeSource AncestorType=mah:MetroWindow}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource IconButtonStyle}"
                                                        ToolTip="{i18n:Translate Main_ChatRewind}"
                                                        Margin="0,0,4,0">
                                                    <Viewbox Width="15"
                                                             Height="15">
                                                        <Path Data="M 13,4 L 6,11 L 13,18 M 7,11 L 19,11"
                                                              Stroke="{DynamicResource Perelegans.SubtleForegroundBrush}"
                                                              Style="{StaticResource LineIconPathStyle}"/>
                                                    </Viewbox>
                                                </Button>
                                                <Button Width="30"
                                                        Height="30"
                                                        Command="{Binding DataContext.DeleteConversationMessageCommand, RelativeSource={RelativeSource AncestorType=mah:MetroWindow}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource IconButtonStyle}"
                                                        ToolTip="{i18n:Translate Main_ChatDelete}"
                                                        Margin="0,0,4,0">
                                                    <Viewbox Width="13"
                                                             Height="13">
                                                        <Path Data="M 6,6 L 18,18 M 18,6 L 6,18"
                                                              Stroke="{DynamicResource Perelegans.SubtleForegroundBrush}"
                                                              Style="{StaticResource LineIconPathStyle}"/>
                                                    </Viewbox>
                                                </Button>
                                                <Button Content="{i18n:Translate Main_ChatStop}"
                                                        Command="{Binding DataContext.StopAssistantOutputCommand, RelativeSource={RelativeSource AncestorType=mah:MetroWindow}}"
                                                        Style="{StaticResource PresetButtonStyle}"
                                                        Margin="0"
                                                        Visibility="{Binding IsStreaming, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                            </StackPanel>
                                            <Border Margin="0,14,0,0"
                                                    Padding="14"
                                                    Background="{DynamicResource Perelegans.WindowBackground}"
                                                    BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                                                    BorderThickness="1"
                                                    Visibility="{Binding HasUsageStats, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="178"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Width="168"
                                                            Height="168"
                                                            HorizontalAlignment="Left"
                                                            ClipToBounds="True">
                                                        <Viewbox Stretch="Uniform">
                                                            <ItemsControl Width="100"
                                                                          Height="100"
                                                                          ItemsSource="{Binding UsageStats.Slices}">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <Canvas Width="100" Height="100"/>
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemContainerStyle>
                                                                    <Style TargetType="ContentPresenter">
                                                                        <Setter Property="Canvas.Left" Value="0"/>
                                                                        <Setter Property="Canvas.Top" Value="0"/>
                                                                    </Style>
                                                                </ItemsControl.ItemContainerStyle>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Path Data="{Binding PieGeometry}"
                                                                              Fill="{Binding Fill}"
                                                                              Stroke="{DynamicResource Perelegans.StatsChartSliceBorderBrush}"
                                                                              StrokeThickness="0.85"/>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </Viewbox>
                                                    </Border>
                                                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                                        <TextBlock Text="{Binding UsageStats.Title}"
                                                                   FontSize="14"
                                                                   FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding UsageStats.Subtitle}"
                                                                   Margin="0,3,0,10"
                                                                   Style="{StaticResource QuietTextStyle}"/>
                                                        <TextBlock Text="{Binding UsageStats.TotalText}"
                                                                   Margin="0,0,0,10"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#FFFF8FC3"/>
                                                        <ItemsControl ItemsSource="{Binding UsageStats.Slices}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Grid Margin="0,0,0,7">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="12"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <Ellipse Width="8"
                                                                                 Height="8"
                                                                                 Fill="{Binding Fill}"
                                                                                 VerticalAlignment="Center"/>
                                                                        <TextBlock Grid.Column="1"
                                                                                   Text="{Binding ProcessName}"
                                                                                   Margin="7,0,10,0"
                                                                                   FontSize="12"
                                                                                   TextTrimming="CharacterEllipsis"/>
                                                                        <TextBlock Grid.Column="2"
                                                                                   Text="{Binding ShareText}"
                                                                                   FontSize="12"
                                                                                   Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                                                                    </Grid>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsUser}" Value="True">
                                        <Setter TargetName="Bubble" Property="Background" Value="{DynamicResource Perelegans.StatsChartHighlightBackground}"/>
                                        <Setter TargetName="Bubble" Property="BorderBrush" Value="{DynamicResource Perelegans.AccentBrush}"/>
                                        <Setter TargetName="BubbleText" Property="Foreground" Value="{DynamicResource Perelegans.ForegroundBrush}"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Border Margin="0,0,0,12"
                            Padding="13,9"
                            MaxWidth="560"
                            HorizontalAlignment="Left"
                            Background="{DynamicResource Perelegans.PanelBackground}"
                            BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                            BorderThickness="1"
                            Visibility="{Binding IsAssistantThinking, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Grid Width="18" Height="18" Margin="0,0,9,0">
                                <Ellipse Fill="#FFF28AB7"
                                         Opacity="0.32"
                                         RenderTransformOrigin="0.5,0.5">
                                    <Ellipse.RenderTransform>
                                        <ScaleTransform ScaleX="0.78" ScaleY="0.78"/>
                                    </Ellipse.RenderTransform>
                                    <Ellipse.Effect>
                                        <DropShadowEffect BlurRadius="18"
                                                          ShadowDepth="0"
                                                          Opacity="0.75"
                                                          Color="#FFF28AB7"/>
                                    </Ellipse.Effect>
                                    <Ellipse.Triggers>
                                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     To="0.72"
                                                                     Duration="0:0:1.15"/>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                     To="1.25"
                                                                     Duration="0:0:1.15"/>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                     To="1.25"
                                                                     Duration="0:0:1.15"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Ellipse.Triggers>
                                </Ellipse>
                                <Ellipse Width="8"
                                         Height="8"
                                         Fill="#FFFF8FC3"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="{Binding AssistantThinkingText}"
                                       FontSize="13"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2"
                    Margin="28,0,28,16"
                    Padding="10"
                    CornerRadius="0"
                    Background="{DynamicResource Perelegans.PanelBackground}"
                    BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                    BorderThickness="1"
                    Style="{StaticResource BottomComposerStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             Height="36"
                             Padding="4,0"
                             BorderThickness="0"
                             Background="Transparent"
                             VerticalContentAlignment="Center"
                             FontSize="14"
                             Text="{Binding ConversationInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             mah:TextBoxHelper.Watermark="{i18n:Translate Main_InputWatermark}">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding SendConversationMessageCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>

                    <Button Grid.Column="2"
                            Content="{i18n:Translate Main_Send}"
                            Width="76"
                            Height="34"
                            HorizontalContentAlignment="Center"
                            Command="{Binding SendConversationMessageCommand}"
                            Style="{StaticResource AccentLineButtonStyle}"/>
                </Grid>
            </Border>

            <DockPanel Grid.Row="3" Margin="28,0,28,18">
                <TextBlock Text="{Binding StatusText}"
                           Style="{StaticResource QuietTextStyle}"/>
            </DockPanel>

            <Border Grid.Row="1"
                    Grid.RowSpan="2"
                    Width="640"
                    Padding="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="Transparent"
                    Style="{StaticResource HeroComposerStyle}">
                <StackPanel>
                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,28">
                        <TextBlock Text="{i18n:Translate Main_PrimaryPrompt}"
                                   FontSize="34"
                                   FontWeight="SemiBold"
                                   TextAlignment="Center"/>
                        <TextBlock Text="{Binding CurrentFocusGoalDisplay}"
                                   Margin="0,8,0,0"
                                   FontSize="13"
                                   TextAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                    </StackPanel>

                    <Border CornerRadius="0"
                            Padding="16,14"
                            Background="{DynamicResource Perelegans.PanelBackground}"
                            BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBox Grid.Row="0"
                                     MinHeight="74"
                                     FontSize="15"
                                     Padding="0"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="False"
                                     VerticalContentAlignment="Top"
                                     Text="{Binding ConversationInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     mah:TextBoxHelper.Watermark="{i18n:Translate Main_InputWatermark}">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter" Command="{Binding SendConversationMessageCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>

                            <DockPanel Grid.Row="2" LastChildFill="False">
                                <WrapPanel DockPanel.Dock="Left">
                                    <Button Content="{i18n:Translate Main_PresetDeepWork}"
                                            Command="{Binding UseGoalPresetCommand}"
                                            CommandParameter="{i18n:Translate Main_PresetDeepWorkPrompt}"
                                            Style="{StaticResource PresetButtonStyle}"/>
                                    <Button Content="{i18n:Translate Main_PresetStudy}"
                                            Command="{Binding UseGoalPresetCommand}"
                                            CommandParameter="{i18n:Translate Main_PresetStudyPrompt}"
                                            Style="{StaticResource PresetButtonStyle}"/>
                                    <Button Content="{i18n:Translate Main_PresetWriting}"
                                            Command="{Binding UseGoalPresetCommand}"
                                            CommandParameter="{i18n:Translate Main_PresetWritingPrompt}"
                                            Style="{StaticResource PresetButtonStyle}"/>
                                    <Button Content="{i18n:Translate Main_PresetCoding}"
                                            Command="{Binding UseGoalPresetCommand}"
                                            CommandParameter="{i18n:Translate Main_PresetCodingPrompt}"
                                            Style="{StaticResource PresetButtonStyle}"/>
                                </WrapPanel>

                                <Button Content="{i18n:Translate Main_Send}"
                                        Width="76"
                                        Height="30"
                                        HorizontalContentAlignment="Center"
                                        Command="{Binding SendConversationMessageCommand}"
                                        Style="{StaticResource AccentLineButtonStyle}"/>
                            </DockPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.RowSpan="4"
                    Margin="24"
                    Padding="18"
                    CornerRadius="0"
                    Background="{DynamicResource Perelegans.WindowBackground}"
                    BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                    BorderThickness="1"
                    Visibility="{Binding IsStatisticsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,16">
                        <Button DockPanel.Dock="Right"
                                Content="{i18n:Translate Main_CloseStatistics}"
                                Command="{Binding ToggleStatisticsCommand}"
                                Style="{StaticResource PresetButtonStyle}"
                                Margin="0"/>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="0,0,10,0">
                            <Button Content="{i18n:Translate Main_UsageStatsDaily}"
                                    Command="{Binding SetUsageStatsPeriodCommand}"
                                    CommandParameter="day"
                                    Style="{StaticResource PresetButtonStyle}"
                                    Margin="0,0,6,0"/>
                            <Button Content="{i18n:Translate Main_UsageStatsMonthly}"
                                    Command="{Binding SetUsageStatsPeriodCommand}"
                                    CommandParameter="month"
                                    Style="{StaticResource PresetButtonStyle}"
                                    Margin="0"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="{Binding UsageStatsTitle}"
                                       FontSize="22"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding UsageStatsSubtitle}"
                                       Margin="0,4,0,0"
                                       Style="{StaticResource QuietTextStyle}"/>
                        </StackPanel>
                    </DockPanel>

                    <Border Grid.Row="1"
                            Background="{DynamicResource Perelegans.StatsChartPanelBackground}"
                            BorderBrush="{DynamicResource Perelegans.StatsChartPanelBorderBrush}"
                            BorderThickness="1"
                            Padding="18,16,18,14"
                            ClipToBounds="True">
                        <Grid ClipToBounds="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Background="{DynamicResource Perelegans.StatsChartMetricBackground}"
                                        Padding="10,8">
                                    <StackPanel>
                                        <TextBlock Text="{i18n:Translate Main_UsageStatsTotal}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                                        <TextBlock Text="{Binding UsageStatsTotalText}"
                                                   Margin="0,2,0,0"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2"
                                        Background="{DynamicResource Perelegans.StatsChartMetricBackground}"
                                        Padding="10,8">
                                    <StackPanel>
                                        <TextBlock Text="{i18n:Translate Main_UsageStatsProcesses}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                                        <TextBlock Text="{Binding UsageStatsSlices.Count}"
                                                   Margin="0,2,0,0"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Grid Grid.Row="1"
                                  Margin="0,22,0,14"
                                  MouseLeave="UsagePieChart_MouseLeave">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="310"/>
                                    <ColumnDefinition Width="18"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Height="248"
                                        Padding="8"
                                        ClipToBounds="True">
                                    <Grid ClipToBounds="True">
                                        <Viewbox Stretch="Uniform">
                                            <Canvas Width="100" Height="100">
                                                <ItemsControl ItemsSource="{Binding UsageStatsSlices}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <Canvas Width="100" Height="100"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemContainerStyle>
                                                        <Style TargetType="ContentPresenter">
                                                            <Setter Property="Canvas.Left" Value="0"/>
                                                            <Setter Property="Canvas.Top" Value="0"/>
                                                        </Style>
                                                    </ItemsControl.ItemContainerStyle>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Path Data="{Binding PieGeometry}"
                                                                  Fill="{Binding Fill}"
                                                                  Stroke="{DynamicResource Perelegans.WindowBackground}"
                                                                  StrokeThickness="0.7"
                                                                  RenderTransformOrigin="0.5,0.5"
                                                                  MouseEnter="UsageSlicePath_MouseEnter">
                                                                <Path.Style>
                                                                    <Style TargetType="Path">
                                                                        <Setter Property="Opacity" Value="0.96"/>
                                                                        <Setter Property="RenderTransform">
                                                                            <Setter.Value>
                                                                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                                                                <Setter Property="Opacity" Value="1"/>
                                                                                <Setter Property="StrokeThickness" Value="1.2"/>
                                                                                <Setter Property="RenderTransform">
                                                                                    <Setter.Value>
                                                                                        <ScaleTransform ScaleX="1.035" ScaleY="1.035"/>
                                                                                    </Setter.Value>
                                                                                </Setter>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Path.Style>
                                                            </Path>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Canvas>
                                        </Viewbox>
                                        <TextBlock Text="{Binding UsageStatsEmptyText}"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap"
                                                   FontSize="14"
                                                   Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasUsageStatsSlices}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="2"
                                        Height="248"
                                        Padding="12,12,12,10"
                                        Background="{DynamicResource Perelegans.StatsChartMetricBackground}"
                                        BorderBrush="{DynamicResource Perelegans.StatsChartPanelBorderBrush}"
                                        BorderThickness="1"
                                        ClipToBounds="True">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="{Binding UsageStatsTimelineTitle}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Perelegans.ForegroundBrush}"/>
                                        <ScrollViewer Grid.Row="1"
                                                      Margin="0,10,0,8"
                                                      VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Disabled">
                                            <ItemsControl ItemsSource="{Binding UsageTimelineRows}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Height="18">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="88"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="{Binding ProcessName}"
                                                                       FontSize="10"
                                                                       Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       VerticalAlignment="Center"/>
                                                            <Border Grid.Column="1"
                                                                    Height="1"
                                                                    Background="{DynamicResource Perelegans.StatsChartPanelBorderBrush}"
                                                                    VerticalAlignment="Center"
                                                                    Opacity="0.65"/>
                                                            <Viewbox Grid.Column="1"
                                                                     Height="12"
                                                                     Stretch="Fill"
                                                                     VerticalAlignment="Center">
                                                                <ItemsControl Width="100"
                                                                              Height="12"
                                                                              ItemsSource="{Binding Segments}">
                                                                    <ItemsControl.ItemsPanel>
                                                                        <ItemsPanelTemplate>
                                                                            <Canvas Width="100" Height="12"/>
                                                                        </ItemsPanelTemplate>
                                                                    </ItemsControl.ItemsPanel>
                                                                    <ItemsControl.ItemContainerStyle>
                                                                        <Style TargetType="ContentPresenter">
                                                                            <Setter Property="Canvas.Left" Value="{Binding Left}"/>
                                                                            <Setter Property="Canvas.Top" Value="2"/>
                                                                        </Style>
                                                                    </ItemsControl.ItemContainerStyle>
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Border Width="{Binding Width}"
                                                                                    Height="8"
                                                                                    Background="{Binding Fill}"
                                                                                    ToolTip="{Binding Tooltip}"/>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </Viewbox>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                        <Grid Grid.Row="2"
                                              Margin="88,0,0,0"
                                              Height="16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding UsageTimelineStartLabel}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"
                                                       HorizontalAlignment="Left"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding UsageTimelineMiddleLabel}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding UsageTimelineEndLabel}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"
                                                       HorizontalAlignment="Right"/>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>

                            <Border Grid.Row="2"
                                    Height="1"
                                    Margin="0,0,0,12"
                                    Background="{DynamicResource Perelegans.StatsChartPanelBorderBrush}"/>

                            <ScrollViewer Grid.Row="3"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          ClipToBounds="True">
                                <ItemsControl ItemsSource="{Binding UsageStatsSlices}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border x:Name="LegendItemBorder"
                                                    Margin="0,0,0,8"
                                                    Padding="8,6"
                                                    Background="Transparent"
                                                    BorderBrush="Transparent"
                                                    BorderThickness="1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Width="10"
                                                            Height="10"
                                                            Background="{Binding SwatchBrush}"
                                                            VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="1" Margin="8,0,8,0">
                                                        <TextBlock x:Name="LegendTitleText"
                                                                   Text="{Binding Title}"
                                                                   FontSize="12"
                                                                   Foreground="{DynamicResource Perelegans.ForegroundBrush}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding PlaytimeText}"
                                                                   FontSize="11"
                                                                   Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                                                    </StackPanel>
                                                    <TextBlock x:Name="LegendPercentageText"
                                                               Grid.Column="2"
                                                               Text="{Binding PercentageText}"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource Perelegans.ForegroundBrush}"
                                                               VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                                    <Setter TargetName="LegendItemBorder" Property="Background" Value="{DynamicResource Perelegans.StatsChartHighlightBackground}"/>
                                                    <Setter TargetName="LegendItemBorder" Property="BorderBrush" Value="{DynamicResource Perelegans.StatsChartHighlightBorderBrush}"/>
                                                    <Setter TargetName="LegendTitleText" Property="FontWeight" Value="SemiBold"/>
                                                    <Setter TargetName="LegendPercentageText" Property="Foreground" Value="{DynamicResource Perelegans.StatsChartHighlightBorderBrush}"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.RowSpan="4"
                    Margin="24"
                    Padding="18"
                    CornerRadius="0"
                    Background="{DynamicResource Perelegans.WindowBackground}"
                    BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                    BorderThickness="1"
                    Visibility="{Binding IsGalaxyVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,12">
                        <Button DockPanel.Dock="Right"
                                Content="{i18n:Translate Main_CloseGalaxy}"
                                Command="{Binding ToggleGalaxyCommand}"
                                Style="{StaticResource PresetButtonStyle}"
                                Margin="0"/>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="0,0,10,0">
                            <Button Content="{i18n:Translate Main_MemoryPreviewGalaxy}"
                                    Command="{Binding SetMemoryPreviewModeCommand}"
                                    CommandParameter="galaxy"
                                    Style="{StaticResource PresetButtonStyle}"
                                    Margin="0,0,6,0"/>
                            <Button Content="{i18n:Translate Main_MemoryPreviewFishbone}"
                                    Command="{Binding SetMemoryPreviewModeCommand}"
                                    CommandParameter="fishbone"
                                    Style="{StaticResource PresetButtonStyle}"
                                    Margin="0"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="{i18n:Translate Main_GalaxyTitle}"
                                       FontSize="22"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding MemoryCountText}"
                                       Margin="0,4,0,0"
                                       Style="{StaticResource QuietTextStyle}"/>
                        </StackPanel>
                    </DockPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="280"/>
                        </Grid.ColumnDefinitions>

                        <ScrollViewer x:Name="GalaxyMapScrollViewer"
                                      Grid.Column="0"
                                      Background="Transparent"
                                      Cursor="SizeAll"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Hidden"
                                      PanningMode="Both"
                                      PreviewMouseLeftButtonDown="GalaxyMapScrollViewer_MouseLeftButtonDown"
                                      MouseMove="GalaxyMapScrollViewer_MouseMove"
                                      MouseLeftButtonUp="GalaxyMapScrollViewer_MouseLeftButtonUp"
                                      MouseLeave="GalaxyMapScrollViewer_MouseLeave"
                                      PreviewMouseWheel="GalaxyScrollViewer_PreviewMouseWheel"
                                      Visibility="{Binding IsGalaxyPreviewMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid x:Name="GalaxyMapSurface" Width="920" Height="640" Background="Transparent" ClipToBounds="True">
                            <Grid.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform x:Name="GalaxyScaleTransform" ScaleX="1" ScaleY="1"/>
                                    <TranslateTransform x:Name="GalaxyMapPanTransform" X="0" Y="0"/>
                                </TransformGroup>
                            </Grid.RenderTransform>

                            <ItemsControl ItemsSource="{Binding GalaxyLinks}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas Width="920" Height="640"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Line X1="{Binding X1}"
                                              Y1="{Binding Y1}"
                                              X2="{Binding X2}"
                                              Y2="{Binding Y2}"
                                              Stroke="{DynamicResource Perelegans.AccentBrush}"
                                              StrokeThickness="1.2"
                                              Opacity="{Binding Opacity}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <ItemsControl ItemsSource="{Binding ContextMemories}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas Width="920" Height="640"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                        <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="156"
                                                Padding="4"
                                                Background="Transparent"
                                                Cursor="Hand"
                                                MouseLeftButtonDown="GalaxyTask_MouseLeftButtonDown"
                                                MouseMove="GalaxyTask_MouseMove"
                                                MouseLeftButtonUp="GalaxyTask_MouseLeftButtonUp">
                                            <Border.RenderTransform>
                                                <TransformGroup>
                                                    <ScaleTransform x:Name="NodeScale" ScaleX="1" ScaleY="1"/>
                                                    <TranslateTransform x:Name="NodeFloat" Y="0"/>
                                                </TransformGroup>
                                            </Border.RenderTransform>
                                            <Border.Triggers>
                                                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                             From="0"
                                                                             To="1"
                                                                             Duration="0:0:0.24"/>
                                                            <DoubleAnimation Storyboard.TargetName="NodeScale"
                                                                             Storyboard.TargetProperty="ScaleX"
                                                                             From="0.82"
                                                                             To="1"
                                                                             Duration="0:0:0.24">
                                                                <DoubleAnimation.EasingFunction>
                                                                    <CubicEase EasingMode="EaseOut"/>
                                                                </DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                            <DoubleAnimation Storyboard.TargetName="NodeScale"
                                                                             Storyboard.TargetProperty="ScaleY"
                                                                             From="0.82"
                                                                             To="1"
                                                                             Duration="0:0:0.24">
                                                                <DoubleAnimation.EasingFunction>
                                                                    <CubicEase EasingMode="EaseOut"/>
                                                                </DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                                <EventTrigger RoutedEvent="MouseEnter">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="NodeScale"
                                                                             Storyboard.TargetProperty="ScaleX"
                                                                             To="1.06"
                                                                             Duration="0:0:0.12"/>
                                                            <DoubleAnimation Storyboard.TargetName="NodeScale"
                                                                             Storyboard.TargetProperty="ScaleY"
                                                                             To="1.06"
                                                                             Duration="0:0:0.12"/>
                                                            <DoubleAnimation Storyboard.TargetName="NodeFloat"
                                                                             Storyboard.TargetProperty="Y"
                                                                             To="-3"
                                                                             Duration="0:0:0.12"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                                <EventTrigger RoutedEvent="MouseLeave">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="NodeScale"
                                                                             Storyboard.TargetProperty="ScaleX"
                                                                             To="1"
                                                                             Duration="0:0:0.12"/>
                                                            <DoubleAnimation Storyboard.TargetName="NodeScale"
                                                                             Storyboard.TargetProperty="ScaleY"
                                                                             To="1"
                                                                             Duration="0:0:0.12"/>
                                                            <DoubleAnimation Storyboard.TargetName="NodeFloat"
                                                                             Storyboard.TargetProperty="Y"
                                                                             To="0"
                                                                             Duration="0:0:0.12"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Border.Triggers>
                                            <StackPanel Width="148">
                                                <Grid Width="{Binding NodeSize}"
                                                      Height="{Binding NodeSize}"
                                                      HorizontalAlignment="Left">
                                                    <Ellipse x:Name="NodeRing"
                                                             Fill="Transparent"
                                                             Stroke="{DynamicResource Perelegans.AccentBrush}"
                                                             StrokeThickness="1"
                                                             Opacity="0.5"/>
                                                    <Ellipse x:Name="NodeCore"
                                                             Margin="4"
                                                             Fill="{DynamicResource Perelegans.AccentBrush}">
                                                        <Ellipse.Effect>
                                                            <DropShadowEffect BlurRadius="14"
                                                                              ShadowDepth="0"
                                                                              Opacity="0.45"
                                                                              Color="#DFA8B5"/>
                                                        </Ellipse.Effect>
                                                    </Ellipse>
                                                </Grid>
                                                <TextBlock Text="{Binding TypeText}"
                                                           Margin="0,4,0,0"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           LineHeight="16"
                                                           Foreground="{DynamicResource Perelegans.ForegroundBrush}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Preview}"
                                                           Margin="0,1,0,0"
                                                           MaxHeight="34"
                                                           FontSize="12"
                                                           LineHeight="16"
                                                           Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"
                                                           TextWrapping="Wrap"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Tags}"
                                                           Margin="0,2,0,0"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           LineHeight="16"
                                                           Foreground="{DynamicResource Perelegans.AccentBrush}"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="{i18n:Translate Main_GalaxyEmpty}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="15"
                                       Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ContextMemories.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                        </ScrollViewer>

                        <Border Grid.Column="0"
                                Padding="20"
                                Background="{DynamicResource Perelegans.WindowBackground}"
                                BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                                BorderThickness="1"
                                Visibility="{Binding IsFishbonePreviewMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,22">
                                        <StackPanel DockPanel.Dock="Left">
                                            <TextBlock Text="{i18n:Translate Main_MemoryPreviewFishbone}"
                                                       FontSize="19"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding MemoryCountText}"
                                                       Margin="0,5,0,0"
                                                       Style="{StaticResource QuietTextStyle}"/>
                                        </StackPanel>
                                        <Rectangle Height="1"
                                                   Margin="18,18,0,0"
                                                   Fill="{DynamicResource Perelegans.BorderBrush}"
                                                   Opacity="0.9"/>
                                    </DockPanel>

                                    <ItemsControl ItemsSource="{Binding FishboneBranches}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid MinHeight="118"
                                                      Margin="0,0,0,18">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="82"/>
                                                        <ColumnDefinition Width="62"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Grid Grid.Column="0">
                                                        <Border Width="48"
                                                                Height="48"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                Background="{DynamicResource Perelegans.PanelBackground}"
                                                                BorderBrush="{DynamicResource Perelegans.AccentBrush}"
                                                                BorderThickness="1">
                                                            <TextBlock Text="{Binding BranchNumber}"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       FontSize="16"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource Perelegans.AccentBrush}"/>
                                                        </Border>
                                                    </Grid>

                                                    <Grid Grid.Column="1">
                                                        <Rectangle Width="1.4"
                                                                   HorizontalAlignment="Center"
                                                                   Fill="{DynamicResource Perelegans.BorderBrush}"
                                                                   Opacity="0.86"/>
                                                        <Rectangle Height="1.4"
                                                                   Margin="31,0,0,0"
                                                                   VerticalAlignment="Center"
                                                                   Fill="{DynamicResource Perelegans.BorderBrush}"
                                                                   Opacity="0.86"/>
                                                        <Ellipse Width="10"
                                                                 Height="10"
                                                                 HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center"
                                                                 Fill="{DynamicResource Perelegans.AccentBrush}"/>
                                                    </Grid>

                                                    <Border Grid.Column="2"
                                                            Padding="14,12"
                                                            VerticalAlignment="Center"
                                                            Background="{DynamicResource Perelegans.PanelBackground}"
                                                            BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                                                            BorderThickness="1">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Text="{Binding Title}"
                                                                           FontSize="14"
                                                                           FontWeight="SemiBold"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                                <Border Grid.Column="1"
                                                                        MinWidth="74"
                                                                        Margin="12,0,0,0"
                                                                        Padding="7,2"
                                                                        BorderBrush="{DynamicResource Perelegans.AccentBrush}"
                                                                        BorderThickness="1">
                                                                    <TextBlock Text="{Binding MetaText}"
                                                                               FontSize="10"
                                                                               Foreground="{DynamicResource Perelegans.AccentBrush}"
                                                                               TextAlignment="Center"/>
                                                                </Border>
                                                            </Grid>
                                                            <TextBlock Grid.Row="1"
                                                                       Text="{Binding Items}"
                                                                       Margin="0,8,0,0"
                                                                       MaxHeight="42"
                                                                       TextWrapping="Wrap"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       Foreground="{DynamicResource Perelegans.ForegroundBrush}"
                                                                       FontSize="12"/>
                                                            <TextBlock Grid.Row="2"
                                                                       Text="{Binding Tags}"
                                                                       Margin="0,7,0,0"
                                                                       MaxHeight="32"
                                                                       TextWrapping="Wrap"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       Foreground="{DynamicResource Perelegans.AccentBrush}"
                                                                       FontSize="11"/>
                                                        </Grid>
                                                    </Border>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <Border Grid.Column="1"
                                Margin="16,0,0,0"
                                Padding="14"
                                Background="{DynamicResource Perelegans.PanelBackground}"
                                BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                                BorderThickness="1">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>
                                <TextBlock Text="{i18n:Translate Main_GalaxyEditTitle}"
                                           FontSize="15"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="{i18n:Translate Main_GalaxyEditHint}"
                                           Margin="0,4,0,14"
                                           TextWrapping="Wrap"
                                           Style="{StaticResource QuietTextStyle}"/>

                                <TextBlock Text="{i18n:Translate Main_GalaxyTaskTitle}"
                                           Style="{StaticResource QuietTextStyle}"/>
                                <TextBox Margin="0,5,0,12"
                                         Height="32"
                                         Padding="8,0"
                                         VerticalContentAlignment="Center"
                                         IsEnabled="{Binding HasSelectedGalaxyTask}"
                                         Text="{Binding GalaxyEditTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                <TextBlock Text="{i18n:Translate Main_GalaxyTaskTime}"
                                           Style="{StaticResource QuietTextStyle}"/>
                                <TextBox Margin="0,5,0,12"
                                         Height="32"
                                         Padding="8,0"
                                         VerticalContentAlignment="Center"
                                         IsEnabled="{Binding HasSelectedGalaxyTask}"
                                         Text="{Binding GalaxyEditCreatedAtText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                <CheckBox Content="{i18n:Translate Main_GalaxyTaskCompleted}"
                                          Margin="0,2,0,8"
                                          IsEnabled="{Binding HasSelectedGalaxyTask}"
                                          Visibility="{Binding SelectedGalaxyMemory.IsPlan, Converter={StaticResource BooleanToVisibilityConverter}}"
                                          IsChecked="{Binding GalaxyEditIsCompleted, Mode=TwoWay}"/>
                                <CheckBox Content="{i18n:Translate Main_GalaxyTaskAbandoned}"
                                          Margin="0,0,0,16"
                                          IsEnabled="{Binding HasSelectedGalaxyTask}"
                                          Visibility="{Binding SelectedGalaxyMemory.IsPlan, Converter={StaticResource BooleanToVisibilityConverter}}"
                                          IsChecked="{Binding GalaxyEditIsAbandoned, Mode=TwoWay}"/>

                                 <TextBlock Text="{i18n:Translate Main_GalaxyTaskInsight}"
                                            Margin="0,0,0,5"
                                            Style="{StaticResource QuietTextStyle}"/>
                                <TextBlock Text="{Binding SelectedGalaxyMemory.AiDescription}"
                                            Margin="0,0,0,10"
                                            TextWrapping="Wrap"
                                            FontSize="12"/>

                                <TextBlock Text="{i18n:Translate Main_GalaxyTaskExplanation}"
                                           Style="{StaticResource QuietTextStyle}"/>
                                <TextBlock Text="{Binding SelectedGalaxyMemory.AiExplanation}"
                                           Margin="0,5,0,10"
                                           TextWrapping="Wrap"
                                           FontSize="12"/>

                                <TextBlock Text="{i18n:Translate Main_GalaxyTaskNextAction}"
                                           Style="{StaticResource QuietTextStyle}"/>
                                <TextBlock Text="{Binding SelectedGalaxyMemory.NextPrediction}"
                                            Margin="0,5,0,10"
                                            TextWrapping="Wrap"
                                            FontSize="12"/>

                                <TextBlock Text="{Binding SelectedGalaxyMemory.Tags, StringFormat={}{0}}"
                                           Margin="0,0,0,4"
                                           FontSize="11"
                                           Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                                <TextBlock Text="{Binding SelectedGalaxyMemory.ConstellationName}"
                                           Margin="0,0,0,16"
                                           FontSize="11"
                                           Foreground="{DynamicResource Perelegans.AccentBrush}"/>
                                <TextBlock Text="{Binding SelectedGalaxyMemory.InsightMetaText}"
                                           Margin="0,0,0,16"
                                           FontSize="11"
                                           Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>

                                <Button Content="{i18n:Translate Main_GalaxyTaskSave}"
                                        Command="{Binding SaveGalaxyTaskCommand}"
                                        HorizontalContentAlignment="Center"
                                        Style="{StaticResource AccentLineButtonStyle}"
                                        Margin="0,0,0,8"/>
                                <Button Content="{i18n:Translate Main_GalaxyTaskDelete}"
                                        Command="{Binding DeleteGalaxyTaskCommand}"
                                        HorizontalContentAlignment="Center"
                                        Style="{StaticResource LineButtonStyle}"
                                        Margin="0"/>
                            </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</mah:MetroWindow>
