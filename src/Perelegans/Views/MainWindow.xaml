                    <DockPanel Grid.Row="0" Margin="0,0,0,16">
                        <Button DockPanel.Dock="Right"
                                Content="关闭"
                                Command="{Binding ToggleCompanionRoomCommand}"
                                Style="{StaticResource LineButtonStyle}"
                                Width="76"
                                HorizontalContentAlignment="Center"/>
                        <StackPanel>
                            <TextBlock Text="伙伴小房间"
                                       FontSize="22"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding PetRoomSummaryText}"
                                       Margin="0,5,0,0"
                                       TextWrapping="Wrap"
                                       Style="{StaticResource QuietTextStyle}"/>
                        </StackPanel>
                    </DockPanel>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.05*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="1.35*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <Border Padding="16"
                                        Background="{DynamicResource Perelegans.PanelBackground}"
                                        BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="112"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid Width="96"
                                              Height="96"
                                              HorizontalAlignment="Left"
                                              RenderOptions.BitmapScalingMode="NearestNeighbor">
                                            <Ellipse Width="84"
                                                     Height="18"
                                                     Margin="0,70,0,0"
                                                     HorizontalAlignment="Center"
                                                     Fill="#30FF9BB9"/>
                                            <Image Width="82"
                                                   Height="82"
                                                   Source="{Binding PetRoomSpriteSource}"
                                                   Stretch="Uniform"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Top"/>
                                        </Grid>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding PetGrowthStageTitle}"
                                                       FontSize="20"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding PetGrowthProgressText}"
                                                       Margin="0,4,0,0"
                                                       Foreground="#FFFF8FC3"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding PetGrowthStageDescription}"
                                                       Margin="0,9,0,0"
                                                       FontSize="12"
                                                       LineHeight="18"
                                                       TextWrapping="Wrap"
                                                       Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <TextBlock Text="成长维度"
                                           Margin="0,18,0,9"
                                           FontSize="15"
                                           FontWeight="SemiBold"/>
                                <ItemsControl ItemsSource="{Binding PetGrowthDimensions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,10"
                                                    Padding="11"
                                                    Background="{DynamicResource Perelegans.PanelBackground}"
                                                    BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                                                    BorderThickness="1">
                                                <StackPanel>
                                                    <DockPanel>
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontSize="13"
                                                                   FontWeight="SemiBold"
                                                                   DockPanel.Dock="Left"/>
                                                        <TextBlock Text="{Binding ProgressText}"
                                                                   FontSize="12"
                                                                   HorizontalAlignment="Right"
                                                                   Foreground="{Binding AccentBrush}"/>
                                                    </DockPanel>
                                                    <ProgressBar Height="6"
                                                                 Margin="0,8,0,7"
                                                                 Minimum="0"
                                                                 Maximum="100"
                                                                 Value="{Binding Percentage, Mode=OneWay}"
                                                                 Foreground="{Binding AccentBrush}"
                                                                 Background="{DynamicResource Perelegans.StatsChartHighlightBackground}"
                                                                 BorderThickness="0"/>
                                                    <TextBlock Text="{Binding Description}"
                                                               FontSize="11"
                                                               LineHeight="16"
                                                               TextWrapping="Wrap"
                                                               Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="能力徽章"
                                           FontSize="15"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding PetUnlockedBadgeCountText}"
                                           Margin="0,4,0,10"
                                           Style="{StaticResource QuietTextStyle}"/>
                                <ItemsControl ItemsSource="{Binding PetAbilityBadges}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="188"
                                                    MinHeight="118"
                                                    Margin="0,0,10,10"
                                                    Padding="12"
                                                    Opacity="{Binding VisualOpacity}"
                                                    Background="{DynamicResource Perelegans.PanelBackground}"
                                                    BorderBrush="{Binding AccentBrush}"
                                                    BorderThickness="1">
                                                <StackPanel>
                                                    <DockPanel Margin="0,0,0,7">
                                                        <Border Width="24"
                                                                Height="24"
                                                                DockPanel.Dock="Left"
                                                                Background="{Binding AccentBrush}">
                                                            <TextBlock Text="{Binding MarkerText}"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       FontWeight="Bold"
                                                                       Foreground="{DynamicResource Perelegans.WindowBackground}"/>
                                                        </Border>
                                                        <TextBlock Text="{Binding StatusText}"
                                                                   FontSize="11"
                                                                   HorizontalAlignment="Right"
                                                                   Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                                                    </DockPanel>
                                                    <TextBlock Text="{Binding Title}"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding Description}"
                                                               Margin="0,5,0,7"
                                                               FontSize="11"
                                                               LineHeight="16"
                                                               TextWrapping="Wrap"
                                                               Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                                                    <TextBlock Text="{Binding DimensionName}"
                                                               FontSize="11"
                                                               Foreground="{Binding AccentBrush}"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="房间陈列"
                                           Margin="0,12,0,9"
                                           FontSize="15"
                                           FontWeight="SemiBold"/>
                                <ItemsControl ItemsSource="{Binding PetRoomItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,8"
                                                    Padding="11"
                                                    Background="{DynamicResource Perelegans.PanelBackground}"
                                                    BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                                                    BorderThickness="1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="10"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Width="6"
                                                            Height="36"
                                                            Background="{Binding AccentBrush}"
                                                            VerticalAlignment="Top"/>
                                                    <StackPanel Grid.Column="1" Margin="9,0,0,0">
                                                        <TextBlock Text="{Binding Title}"
                                                                   FontSize="13"
                                                                   FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding Description}"
                                                                   Margin="0,4,0,0"
                                                                   FontSize="11"
                                                                   LineHeight="16"
                                                                   TextWrapping="Wrap"
                                                                   Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.RowSpan="4"
                    Margin="24"
                    Padding="18"
                    CornerRadius="0"
                    Background="{DynamicResource Perelegans.WindowBackground}"
                    BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                    BorderThickness="1"
                    Visibility="{Binding IsStatisticsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,16">
                        <Button DockPanel.Dock="Right"
                                Content="{i18n:Translate Main_CloseStatistics}"
                                Command="{Binding ToggleStatisticsCommand}"
                                Style="{StaticResource PresetButtonStyle}"
                                Margin="0"/>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="0,0,10,0">
                            <Button Content="{i18n:Translate Main_UsageStatsDaily}"
                                    Command="{Binding SetUsageStatsPeriodCommand}"
                                    CommandParameter="day"
                                    Style="{StaticResource PresetButtonStyle}"
                                    Margin="0,0,6,0"/>
                            <Button Content="{i18n:Translate Main_UsageStatsMonthly}"
                                    Command="{Binding SetUsageStatsPeriodCommand}"
                                    CommandParameter="month"
                                    Style="{StaticResource PresetButtonStyle}"
                                    Margin="0"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="{Binding UsageStatsTitle}"
                                       FontSize="22"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding UsageStatsSubtitle}"
                                       Margin="0,4,0,0"
                                       Style="{StaticResource QuietTextStyle}"/>
                            <TextBlock Text="{Binding UsageStatsInsightText}"
                                       Margin="0,8,0,0"
                                       MaxWidth="760"
                                       TextWrapping="Wrap"
                                       FontSize="13"
                                       LineHeight="19"
                                       Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                        </StackPanel>
                    </DockPanel>

                    <Border Grid.Row="1"
                            Background="{DynamicResource Perelegans.StatsChartPanelBackground}"
                            BorderBrush="{DynamicResource Perelegans.StatsChartPanelBorderBrush}"
                            BorderThickness="1"
                            Padding="18,16,18,14"
                            ClipToBounds="True">
                        <Grid ClipToBounds="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Background="{DynamicResource Perelegans.StatsChartMetricBackground}"
                                        Padding="10,8">
                                    <StackPanel>
                                        <TextBlock Text="{i18n:Translate Main_UsageStatsTotal}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                                        <TextBlock Text="{Binding UsageStatsTotalText}"
                                                   Margin="0,2,0,0"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2"
                                        Background="{DynamicResource Perelegans.StatsChartMetricBackground}"
                                        Padding="10,8">
                                    <StackPanel>
                                        <TextBlock Text="{i18n:Translate Main_UsageStatsProcesses}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                                        <TextBlock Text="{Binding UsageStatsSlices.Count}"
                                                   Margin="0,2,0,0"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Grid Grid.Row="1"
                                  Margin="0,22,0,14"
                                  MouseLeave="UsagePieChart_MouseLeave">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="310"/>
                                    <ColumnDefinition Width="18"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Height="248"
                                        Padding="8"
                                        ClipToBounds="True">
                                    <Grid ClipToBounds="True">
                                        <Viewbox Stretch="Uniform">
                                            <Canvas Width="100" Height="100">
                                                <Ellipse Canvas.Left="8"
                                                         Canvas.Top="8"
                                                         Width="84"
                                                         Height="84"
                                                         Fill="Transparent"
                                                         Stroke="{DynamicResource Perelegans.StatsChartMetricBackground}"
                                                         StrokeThickness="13"
                                                         Opacity="0.62"/>
                                                <ItemsControl ItemsSource="{Binding UsageStatsSlices}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <Canvas Width="100" Height="100"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemContainerStyle>
                                                        <Style TargetType="ContentPresenter">
                                                            <Setter Property="Canvas.Left" Value="0"/>
                                                            <Setter Property="Canvas.Top" Value="0"/>
                                                        </Style>
                                                    </ItemsControl.ItemContainerStyle>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Path Data="{Binding PieGeometry}"
                                                                  Fill="{Binding Fill}"
                                                                  Stroke="{DynamicResource Perelegans.StatsChartSliceBorderBrush}"
                                                                  StrokeThickness="0.55"
                                                                  RenderTransformOrigin="0.5,0.5"
                                                                  MouseEnter="UsageSlicePath_MouseEnter">
                                                                <Path.Style>
                                                                    <Style TargetType="Path">
                                                                        <Setter Property="Opacity" Value="0.78"/>
                                                                        <Setter Property="RenderTransform">
                                                                            <Setter.Value>
                                                                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                                                                <Setter Property="Opacity" Value="1"/>
                                                                                <Setter Property="StrokeThickness" Value="0.95"/>
                                                                                <Setter Property="RenderTransform">
                                                                                    <Setter.Value>
                                                                                        <ScaleTransform ScaleX="1.025" ScaleY="1.025"/>
                                                                                    </Setter.Value>
                                                                                </Setter>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Path.Style>
                                                            </Path>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Canvas>
                                        </Viewbox>
                                        <StackPanel Width="126"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Visibility="{Binding HasUsageStatsSlices, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="{Binding UsagePieCenterTitle}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       TextAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                                            <TextBlock Text="{Binding UsagePieCenterValue}"
                                                       Margin="0,3,0,0"
                                                       FontSize="15"
                                                       FontWeight="SemiBold"
                                                       TextAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{DynamicResource Perelegans.ForegroundBrush}"/>
                                            <TextBlock Text="{Binding UsagePieCenterCaption}"
                                                       Margin="0,2,0,0"
                                                       FontSize="10"
                                                       TextAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{DynamicResource Perelegans.AccentBrush}"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding UsageStatsEmptyText}"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap"
                                                   FontSize="14"
                                                   Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasUsageStatsSlices}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="2"
                                        Height="248"
                                        Padding="12,12,12,10"
                                        Background="{DynamicResource Perelegans.StatsChartMetricBackground}"
                                        BorderBrush="{DynamicResource Perelegans.StatsChartPanelBorderBrush}"
                                        BorderThickness="1"
                                        ClipToBounds="True">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="{Binding UsageStatsTimelineTitle}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Perelegans.ForegroundBrush}"/>
                                        <ScrollViewer Grid.Row="1"
                                                      Margin="0,10,0,8"
                                                      VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Disabled">
                                            <ItemsControl ItemsSource="{Binding UsageTimelineRows}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Height="18">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="88"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="{Binding ProcessName}"
                                                                       FontSize="10"
                                                                       Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       VerticalAlignment="Center"/>
                                                            <Border Grid.Column="1"
                                                                    Height="1"
                                                                    Background="{DynamicResource Perelegans.StatsChartPanelBorderBrush}"
                                                                    VerticalAlignment="Center"
                                                                    Opacity="0.65"/>
                                                            <Viewbox Grid.Column="1"
                                                                     Height="12"
                                                                     Stretch="Fill"
                                                                     VerticalAlignment="Center">
                                                                <ItemsControl Width="100"
                                                                              Height="12"
                                                                              ItemsSource="{Binding Segments}">
                                                                    <ItemsControl.ItemsPanel>
                                                                        <ItemsPanelTemplate>
                                                                            <Canvas Width="100" Height="12"/>
                                                                        </ItemsPanelTemplate>
                                                                    </ItemsControl.ItemsPanel>
                                                                    <ItemsControl.ItemContainerStyle>
                                                                        <Style TargetType="ContentPresenter">
                                                                            <Setter Property="Canvas.Left" Value="{Binding Left}"/>
                                                                            <Setter Property="Canvas.Top" Value="2"/>
                                                                        </Style>
                                                                    </ItemsControl.ItemContainerStyle>
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Border Width="{Binding Width}"
                                                                                    Height="8"
                                                                                    Background="{Binding Fill}"
                                                                                    ToolTip="{Binding Tooltip}"/>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </Viewbox>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                        <Grid Grid.Row="2"
                                              Margin="88,0,0,0"
                                              Height="16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding UsageTimelineStartLabel}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"
                                                       HorizontalAlignment="Left"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding UsageTimelineMiddleLabel}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding UsageTimelineEndLabel}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"
                                                       HorizontalAlignment="Right"/>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>

                            <Border Grid.Row="2"
                                    Height="1"
                                    Margin="0,0,0,12"
                                    Background="{DynamicResource Perelegans.StatsChartPanelBorderBrush}"/>

                            <ScrollViewer Grid.Row="3"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          ClipToBounds="True">
                                <ItemsControl ItemsSource="{Binding UsageStatsSlices}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border x:Name="LegendItemBorder"
                                                    Margin="0,0,0,8"
                                                    Padding="8,6"
                                                    Background="Transparent"
                                                    BorderBrush="Transparent"
                                                    BorderThickness="1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Width="10"
                                                            Height="10"
                                                            Background="{Binding SwatchBrush}"
                                                            Opacity="0.82"
                                                            VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="1" Margin="8,0,8,0">
                                                        <TextBlock x:Name="LegendTitleText"
                                                                   Text="{Binding Title}"
                                                                   FontSize="12"
                                                                   Foreground="{DynamicResource Perelegans.ForegroundBrush}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding PlaytimeText}"
                                                                   FontSize="11"
                                                                   Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                                                    </StackPanel>
                                                    <TextBlock x:Name="LegendPercentageText"
                                                               Grid.Column="2"
                                                               Text="{Binding PercentageText}"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource Perelegans.ForegroundBrush}"
                                                               VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                                    <Setter TargetName="LegendItemBorder" Property="Background" Value="{DynamicResource Perelegans.StatsChartHighlightBackground}"/>
                                                    <Setter TargetName="LegendItemBorder" Property="BorderBrush" Value="{DynamicResource Perelegans.StatsChartHighlightBorderBrush}"/>
                                                    <Setter TargetName="LegendItemBorder" Property="Padding" Value="9,7"/>
                                                    <Setter TargetName="LegendTitleText" Property="FontWeight" Value="SemiBold"/>
                                                    <Setter TargetName="LegendPercentageText" Property="Foreground" Value="{DynamicResource Perelegans.StatsChartHighlightBorderBrush}"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.RowSpan="4"
                    Margin="24"
                    Padding="18"
                    CornerRadius="0"
                    Background="{DynamicResource Perelegans.WindowBackground}"
                    BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                    BorderThickness="1"
                    Visibility="{Binding IsGalaxyVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,12">
                        <Button DockPanel.Dock="Right"
                                Content="{i18n:Translate Main_CloseGalaxy}"
                                Command="{Binding ToggleGalaxyCommand}"
                                Style="{StaticResource PresetButtonStyle}"
                                Margin="0"/>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="0,0,10,0">
                            <Button Content="总览"
                                    Command="{Binding ShowMemoryConstellationOverviewCommand}"
                                    Style="{StaticResource PresetButtonStyle}"
                                    Margin="0,0,6,0"/>
                            <Button Content="{i18n:Translate Main_MemoryPreviewGalaxy}"
                                    Command="{Binding SetMemoryPreviewModeCommand}"
                                    CommandParameter="galaxy"
                                    Style="{StaticResource PresetButtonStyle}"
                                    Margin="0,0,6,0"/>
                            <Button Content="{i18n:Translate Main_MemoryPreviewFishbone}"
                                    Command="{Binding SetMemoryPreviewModeCommand}"
                                    CommandParameter="fishbone"
                                    Style="{StaticResource PresetButtonStyle}"
                                    Margin="0"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="{i18n:Translate Main_GalaxyTitle}"
                                       FontSize="22"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding MemoryCountText}"
                                       Margin="0,4,0,0"
                                       Style="{StaticResource QuietTextStyle}"/>
                        </StackPanel>
                    </DockPanel>

                    <Grid Grid.Row="1" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Height="32"
                                 Padding="9,0"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding GalaxySearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 mah:TextBoxHelper.Watermark="搜索标题、内容、标签"/>
                        <ComboBox Grid.Column="1"
                                  Margin="8,0,0,0"
                                  Height="32"
                                  IsEditable="True"
                                  Text="{Binding GalaxyTagFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  ItemsSource="{Binding AvailableGalaxyTags}"
                                  mah:TextBoxHelper.Watermark="标签"/>
                        <ComboBox Grid.Column="2"
                                  Margin="8,0,0,0"
                                  Height="32"
                                  IsEditable="True"
                                  Text="{Binding GalaxyGroupFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  ItemsSource="{Binding AvailableGalaxyGroups}"
                                  mah:TextBoxHelper.Watermark="分组"/>
                        <Button Grid.Column="3"
                                Content="清除"
                                Command="{Binding ClearGalaxyFiltersCommand}"
                                Style="{StaticResource PresetButtonStyle}"
                                Margin="8,0,0,0"/>
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="280"/>
                        </Grid.ColumnDefinitions>

                        <ScrollViewer x:Name="GalaxyMapScrollViewer"
                                      Grid.Column="0"
                                      Background="Transparent"
                                      Cursor="SizeAll"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Hidden"
                                      PanningMode="Both"
                                      PreviewMouseLeftButtonDown="GalaxyMapScrollViewer_MouseLeftButtonDown"
                                      MouseMove="GalaxyMapScrollViewer_MouseMove"
                                      MouseLeftButtonUp="GalaxyMapScrollViewer_MouseLeftButtonUp"
                                      MouseLeave="GalaxyMapScrollViewer_MouseLeave"
                                      PreviewMouseWheel="GalaxyScrollViewer_PreviewMouseWheel"
                                      Visibility="{Binding IsGalaxyPreviewMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid x:Name="GalaxyMapSurface" Width="920" Height="640" Background="Transparent" ClipToBounds="True">
                            <Grid.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform x:Name="GalaxyScaleTransform" ScaleX="1" ScaleY="1"/>
                                    <TranslateTransform x:Name="GalaxyMapPanTransform" X="0" Y="0"/>
                                </TransformGroup>
                            </Grid.RenderTransform>

                            <ItemsControl ItemsSource="{Binding GalaxyLinks}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas Width="920" Height="640"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Line X1="{Binding X1}"
                                              Y1="{Binding Y1}"
                                              X2="{Binding X2}"
                                              Y2="{Binding Y2}"
                                              Stroke="{DynamicResource Perelegans.AccentBrush}"
                                              StrokeThickness="1.2"
                                              Opacity="{Binding Opacity}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <ItemsControl ItemsSource="{Binding MemoryConstellations}"
                                          Visibility="{Binding IsMemoryConstellationLayer, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas Width="920" Height="640"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                        <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="180"
                                                Padding="6"
                                                Background="Transparent"
                                                Cursor="Hand"
                                                MouseLeftButtonDown="MemoryConstellation_MouseLeftButtonDown">
                                            <StackPanel Width="168"
                                                        Opacity="{Binding VisualOpacity}">
                                                <Grid Width="{Binding NodeSize}"
                                                      Height="{Binding NodeSize}"
                                                      HorizontalAlignment="Left">
                                                    <Ellipse Fill="Transparent"
                                                             Stroke="{DynamicResource Perelegans.AccentBrush}"
                                                             StrokeThickness="1.2"
                                                             Opacity="0.48"/>
                                                    <Ellipse Margin="8"
                                                             Fill="{DynamicResource Perelegans.AccentBrush}"
                                                             Opacity="0.82">
                                                        <Ellipse.Effect>
                                                            <DropShadowEffect BlurRadius="18"
                                                                              ShadowDepth="0"
                                                                              Opacity="0.45"
                                                                              Color="#DFA8B5"/>
                                                        </Ellipse.Effect>
                                                    </Ellipse>
                                                </Grid>
                                                <TextBlock Text="{Binding Title}"
                                                           Margin="0,5,0,0"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           LineHeight="17"
                                                           Foreground="{DynamicResource Perelegans.ForegroundBrush}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding CountText}"
                                                           Margin="0,1,0,0"
                                                           FontSize="12"
                                                           LineHeight="15"
                                                           Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Summary}"
                                                           Margin="0,2,0,0"
                                                           MaxHeight="32"
                                                           FontSize="12"
                                                           LineHeight="16"
                                                           Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"
                                                           TextWrapping="Wrap"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Tags}"
                                                           Margin="0,2,0,0"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           LineHeight="16"
                                                           Foreground="{DynamicResource Perelegans.AccentBrush}"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <ItemsControl ItemsSource="{Binding ContextMemories}"
                                          Visibility="{Binding IsMemoryNodeLayer, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas Width="920" Height="640"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                        <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="156"
                                                Padding="4"
                                                Background="Transparent"
                                                Cursor="Hand"
                                                MouseLeftButtonDown="GalaxyTask_MouseLeftButtonDown"
                                                MouseMove="GalaxyTask_MouseMove"
                                                MouseLeftButtonUp="GalaxyTask_MouseLeftButtonUp">
                                            <Border.RenderTransform>
                                                <TransformGroup>
                                                    <ScaleTransform x:Name="NodeScale" ScaleX="1" ScaleY="1"/>
                                                    <TranslateTransform x:Name="NodeFloat" Y="0"/>
                                                </TransformGroup>
                                            </Border.RenderTransform>
                                            <Border.Triggers>
                                                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                             From="0"
                                                                             To="1"
                                                                             Duration="0:0:0.24"/>
                                                            <DoubleAnimation Storyboard.TargetName="NodeScale"
                                                                             Storyboard.TargetProperty="ScaleX"
                                                                             From="0.82"
                                                                             To="1"
                                                                             Duration="0:0:0.24">
                                                                <DoubleAnimation.EasingFunction>
                                                                    <CubicEase EasingMode="EaseOut"/>
                                                                </DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                            <DoubleAnimation Storyboard.TargetName="NodeScale"
                                                                             Storyboard.TargetProperty="ScaleY"
                                                                             From="0.82"
                                                                             To="1"
                                                                             Duration="0:0:0.24">
                                                                <DoubleAnimation.EasingFunction>
                                                                    <CubicEase EasingMode="EaseOut"/>
                                                                </DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                                <EventTrigger RoutedEvent="MouseEnter">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="NodeScale"
                                                                             Storyboard.TargetProperty="ScaleX"
                                                                             To="1.06"
                                                                             Duration="0:0:0.12"/>
                                                            <DoubleAnimation Storyboard.TargetName="NodeScale"
                                                                             Storyboard.TargetProperty="ScaleY"
                                                                             To="1.06"
                                                                             Duration="0:0:0.12"/>
                                                            <DoubleAnimation Storyboard.TargetName="NodeFloat"
                                                                             Storyboard.TargetProperty="Y"
                                                                             To="-3"
                                                                             Duration="0:0:0.12"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                                <EventTrigger RoutedEvent="MouseLeave">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="NodeScale"
                                                                             Storyboard.TargetProperty="ScaleX"
                                                                             To="1"
                                                                             Duration="0:0:0.12"/>
                                                            <DoubleAnimation Storyboard.TargetName="NodeScale"
                                                                             Storyboard.TargetProperty="ScaleY"
                                                                             To="1"
                                                                             Duration="0:0:0.12"/>
                                                            <DoubleAnimation Storyboard.TargetName="NodeFloat"
                                                                             Storyboard.TargetProperty="Y"
                                                                             To="0"
                                                                             Duration="0:0:0.12"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Border.Triggers>
                                            <StackPanel Width="148"
                                                        Opacity="{Binding VisualOpacity}">
                                                <Grid Width="{Binding NodeSize}"
                                                      Height="{Binding NodeSize}"
                                                      HorizontalAlignment="Left">
                                                    <Ellipse x:Name="NodeRing"
                                                             Fill="Transparent"
                                                             StrokeThickness="1"
                                                             Opacity="0.5">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Stroke" Value="{DynamicResource Perelegans.AccentBrush}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsLowWeight}" Value="True">
                                                                        <Setter Property="Stroke" Value="#FF929292"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>
                                                    <Ellipse x:Name="NodeCore"
                                                             Margin="4">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Fill" Value="{DynamicResource Perelegans.AccentBrush}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsLowWeight}" Value="True">
                                                                        <Setter Property="Fill" Value="#FF8D8D8D"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                        <Ellipse.Effect>
                                                            <DropShadowEffect BlurRadius="14"
                                                                              ShadowDepth="0"
                                                                              Opacity="0.45"
                                                                              Color="#DFA8B5"/>
                                                        </Ellipse.Effect>
                                                    </Ellipse>
                                                </Grid>
                                                <TextBlock Text="{Binding TypeText}"
                                                           Margin="0,4,0,0"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           LineHeight="16"
                                                           Foreground="{DynamicResource Perelegans.ForegroundBrush}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Preview}"
                                                           Margin="0,1,0,0"
                                                           MaxHeight="34"
                                                           FontSize="12"
                                                           LineHeight="16"
                                                           Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"
                                                           TextWrapping="Wrap"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Tags}"
                                                           Margin="0,2,0,0"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           LineHeight="16"
                                                           Foreground="{DynamicResource Perelegans.AccentBrush}"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="{i18n:Translate Main_GalaxyEmpty}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="15"
                                       Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsGalaxyEmpty}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                        </ScrollViewer>

                        <Border Grid.Column="0"
                                Padding="20"
                                Background="{DynamicResource Perelegans.WindowBackground}"
                                BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                                BorderThickness="1"
                                Visibility="{Binding IsFishbonePreviewMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,22">
                                        <StackPanel DockPanel.Dock="Left">
                                            <TextBlock Text="{i18n:Translate Main_MemoryPreviewFishbone}"
                                                       FontSize="19"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding MemoryCountText}"
                                                       Margin="0,5,0,0"
                                                       Style="{StaticResource QuietTextStyle}"/>
                                        </StackPanel>
                                        <Rectangle Height="1"
                                                   Margin="18,18,0,0"
                                                   Fill="{DynamicResource Perelegans.BorderBrush}"
                                                   Opacity="0.9"/>
                                    </DockPanel>

                                    <Canvas Width="2460"
                                            Height="540">
                                        <Rectangle Canvas.Left="34"
                                                   Canvas.Top="268"
                                                   Width="2350"
                                                   Height="2"
                                                   Fill="{DynamicResource Perelegans.BorderBrush}"
                                                   Opacity="0.86"/>
                                        <Polygon Points="2384,258 2418,269 2384,280"
                                                 Fill="{DynamicResource Perelegans.AccentBrush}"
                                                 Opacity="0.82"/>

                                        <ItemsControl ItemsSource="{Binding FishboneBranches}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <Canvas Width="2460"
                                                            Height="540"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemContainerStyle>
                                                <Style TargetType="ContentPresenter">
                                                    <Setter Property="Canvas.Left" Value="{Binding BranchX}"/>
                                                    <Setter Property="Canvas.Top" Value="0"/>
                                                </Style>
                                            </ItemsControl.ItemContainerStyle>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Canvas Width="320"
                                                            Height="540"
                                                            Opacity="{Binding VisualOpacity}">
                                                        <Rectangle x:Name="BranchRib"
                                                                   Canvas.Left="0"
                                                                   Canvas.Top="268"
                                                                   Width="156"
                                                                   Height="2"
                                                                   Fill="{DynamicResource Perelegans.BorderBrush}"
                                                                   Opacity="0.9"
                                                                   RenderTransformOrigin="0,0.5">
                                                            <Rectangle.RenderTransform>
                                                                <RotateTransform Angle="{Binding RibAngle}"/>
                                                            </Rectangle.RenderTransform>
                                                        </Rectangle>
                                                        <Ellipse x:Name="BranchDot"
                                                                 Canvas.Left="-5"
                                                                 Canvas.Top="263"
                                                                 Width="12"
                                                                 Height="12"
                                                                 Fill="{DynamicResource Perelegans.AccentBrush}"/>

                                                        <Border x:Name="BranchCard"
                                                                Canvas.Left="74"
                                                                Canvas.Top="{Binding CardTop}"
                                                                Width="230"
                                                                Padding="10,9"
                                                                Background="{DynamicResource Perelegans.PanelBackground}"
                                                                BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                                                                BorderThickness="1">
                                                            <Grid>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                </Grid.RowDefinitions>
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock x:Name="BranchTitleText"
                                                                               Text="{Binding Title}"
                                                                               FontSize="13"
                                                                               FontWeight="SemiBold"
                                                                               TextTrimming="CharacterEllipsis"/>
                                                                    <Border x:Name="BranchMetaPill"
                                                                            Grid.Column="1"
                                                                            MinWidth="48"
                                                                            Margin="8,0,0,0"
                                                                            Padding="5,1"
                                                                            BorderBrush="{DynamicResource Perelegans.AccentBrush}"
                                                                            BorderThickness="1">
                                                                        <TextBlock x:Name="BranchMetaText"
                                                                                   Text="{Binding MetaText}"
                                                                                   FontSize="9"
                                                                                   Foreground="{DynamicResource Perelegans.AccentBrush}"
                                                                                   TextAlignment="Center"/>
                                                                    </Border>
                                                                </Grid>

                                                                <ScrollViewer Grid.Row="1"
                                                                              Margin="0,8,0,0"
                                                                              MaxHeight="132"
                                                                              VerticalScrollBarVisibility="Auto"
                                                                              HorizontalScrollBarVisibility="Disabled">
                                                                    <ItemsControl ItemsSource="{Binding Memories}">
                                                                        <ItemsControl.ItemsPanel>
                                                                            <ItemsPanelTemplate>
                                                                                <StackPanel/>
                                                                            </ItemsPanelTemplate>
                                                                        </ItemsControl.ItemsPanel>
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <Button Command="{Binding DataContext.SelectGalaxyTaskCommand, RelativeSource={RelativeSource AncestorType={x:Type mah:MetroWindow}}}"
                                                                                        CommandParameter="{Binding Memory}"
                                                                                        Cursor="Hand"
                                                                                        Margin="0,0,0,5"
                                                                                        Padding="7,5"
                                                                                        Background="Transparent"
                                                                                        BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                                                                                        BorderThickness="1"
                                                                                        HorizontalContentAlignment="Stretch"
                                                                                        Opacity="{Binding VisualOpacity}">
                                                                                    <StackPanel>
                                                                                        <TextBlock Text="{Binding Title}"
                                                                                                   FontSize="11"
                                                                                                   FontWeight="SemiBold"
                                                                                                   Foreground="{DynamicResource Perelegans.ForegroundBrush}"
                                                                                                   TextTrimming="CharacterEllipsis"/>
                                                                                        <TextBlock Text="{Binding StatusText}"
                                                                                                   Margin="0,2,0,0"
                                                                                                   FontSize="10"
                                                                                                   Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"
                                                                                                   TextTrimming="CharacterEllipsis"/>
                                                                                    </StackPanel>
                                                                                </Button>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </ScrollViewer>

                                                                <TextBlock x:Name="BranchTagsText"
                                                                           Grid.Row="2"
                                                                           Text="{Binding Tags}"
                                                                           Margin="0,3,0,0"
                                                                           MaxHeight="28"
                                                                           TextWrapping="Wrap"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           Foreground="{DynamicResource Perelegans.AccentBrush}"
                                                                           FontSize="10"/>
                                                            </Grid>
                                                        </Border>
                                                    </Canvas>
                                                    <DataTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding IsLowWeight}" Value="True">
                                                            <Setter TargetName="BranchRib" Property="Fill" Value="#FF9A9A9A"/>
                                                            <Setter TargetName="BranchDot" Property="Fill" Value="#FF8E8E8E"/>
                                                            <Setter TargetName="BranchCard" Property="BorderBrush" Value="#FF9A9A9A"/>
                                                            <Setter TargetName="BranchTitleText" Property="Foreground" Value="#FF777777"/>
                                                            <Setter TargetName="BranchMetaPill" Property="BorderBrush" Value="#FF9A9A9A"/>
                                                            <Setter TargetName="BranchMetaText" Property="Foreground" Value="#FF777777"/>
                                                            <Setter TargetName="BranchTagsText" Property="Foreground" Value="#FF8E8E8E"/>
                                                        </DataTrigger>
                                                    </DataTemplate.Triggers>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Canvas>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <Border Grid.Column="1"
                                Margin="16,0,0,0"
                                Padding="14"
                                Background="{DynamicResource Perelegans.PanelBackground}"
                                BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                                BorderThickness="1">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>
                                <Border Margin="0,0,0,14"
                                        Padding="10"
                                        Background="{DynamicResource Perelegans.WindowBackground}"
                                        BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                                        BorderThickness="1"
                                        Visibility="{Binding HasPendingMemories, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding PendingMemoryCountText}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="AI 发现的线索会先停在这里，确认后才进入星图。"
                                                   Margin="0,4,0,8"
                                                   TextWrapping="Wrap"
                                                   Style="{StaticResource QuietTextStyle}"/>
                                        <ListBox ItemsSource="{Binding PendingContextMemories}"
                                                 SelectedItem="{Binding SelectedGalaxyMemory, Mode=TwoWay}"
                                                 MaxHeight="132"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 Foreground="{DynamicResource Perelegans.ForegroundBrush}">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,4">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="!"
                                                                   Margin="0,0,8,0"
                                                                   FontSize="15"
                                                                   FontWeight="Bold"
                                                                   Foreground="{DynamicResource Perelegans.AccentBrush}"/>
                                                        <StackPanel Grid.Column="1">
                                                            <TextBlock Text="{Binding Title}"
                                                                       FontWeight="SemiBold"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Text="{Binding Preview}"
                                                                       Margin="0,2,0,0"
                                                                       FontSize="11"
                                                                       TextWrapping="Wrap"
                                                                       Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="{i18n:Translate Main_GalaxyEditTitle}"
                                           FontSize="15"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="{i18n:Translate Main_GalaxyEditHint}"
                                           Margin="0,4,0,14"
                                           TextWrapping="Wrap"
                                           Style="{StaticResource QuietTextStyle}"/>

                                <TextBlock Text="{i18n:Translate Main_GalaxyTaskTitle}"
                                           Style="{StaticResource QuietTextStyle}"/>
                                <TextBox Margin="0,5,0,12"
                                         Height="32"
                                         Padding="8,0"
                                         VerticalContentAlignment="Center"
                                         IsEnabled="{Binding HasSelectedGalaxyTask}"
                                         Text="{Binding GalaxyEditTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                <TextBlock Text="{i18n:Translate Main_GalaxyTaskTime}"
                                           Style="{StaticResource QuietTextStyle}"/>
                                <TextBox Margin="0,5,0,12"
                                         Height="32"
                                         Padding="8,0"
                                         VerticalContentAlignment="Center"
                                         IsEnabled="{Binding HasSelectedGalaxyTask}"
                                         Text="{Binding GalaxyEditCreatedAtText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                <TextBlock Text="标签"
                                           Style="{StaticResource QuietTextStyle}"/>
                                <TextBox Margin="0,5,0,12"
                                         Height="32"
                                         Padding="8,0"
                                         VerticalContentAlignment="Center"
                                         IsEnabled="{Binding HasSelectedGalaxyTask}"
                                         Text="{Binding GalaxyEditTags, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                <TextBlock Text="分组"
                                           Style="{StaticResource QuietTextStyle}"/>
                                <ComboBox Margin="0,5,0,12"
                                          Height="32"
                                          IsEditable="True"
                                          IsEnabled="{Binding HasSelectedGalaxyTask}"
                                          Text="{Binding GalaxyEditGroup, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          ItemsSource="{Binding AvailableGalaxyGroups}"/>

                                <CheckBox Content="{i18n:Translate Main_GalaxyTaskCompleted}"
                                          Margin="0,2,0,8"
                                          IsEnabled="{Binding HasSelectedGalaxyTask}"
                                          Visibility="{Binding SelectedGalaxyMemory.IsPlan, Converter={StaticResource BooleanToVisibilityConverter}}"
                                          IsChecked="{Binding GalaxyEditIsCompleted, Mode=TwoWay}"/>
                                <CheckBox Content="{i18n:Translate Main_GalaxyTaskAbandoned}"
                                          Margin="0,0,0,16"
                                          IsEnabled="{Binding HasSelectedGalaxyTask}"
                                          Visibility="{Binding SelectedGalaxyMemory.IsPlan, Converter={StaticResource BooleanToVisibilityConverter}}"
                                          IsChecked="{Binding GalaxyEditIsAbandoned, Mode=TwoWay}"/>

                                 <TextBlock Text="{i18n:Translate Main_GalaxyTaskInsight}"
                                            Margin="0,0,0,5"
                                            Style="{StaticResource QuietTextStyle}"/>
                                <TextBlock Text="{Binding SelectedGalaxyMemory.AiDescription}"
                                            Margin="0,0,0,10"
                                            TextWrapping="Wrap"
                                            FontSize="12"/>

                                <TextBlock Text="{i18n:Translate Main_GalaxyTaskExplanation}"
                                           Style="{StaticResource QuietTextStyle}"/>
                                <TextBlock Text="{Binding SelectedGalaxyMemory.AiExplanation}"
                                           Margin="0,5,0,10"
                                           TextWrapping="Wrap"
                                           FontSize="12"/>

                                <TextBlock Text="{i18n:Translate Main_GalaxyTaskNextAction}"
                                           Style="{StaticResource QuietTextStyle}"/>
                                <TextBlock Text="{Binding SelectedGalaxyMemory.NextPrediction}"
                                            Margin="0,5,0,10"
                                            TextWrapping="Wrap"
                                            FontSize="12"/>

                                <TextBlock Text="{Binding SelectedGalaxyMemory.Tags, StringFormat={}{0}}"
                                           Margin="0,0,0,4"
                                           FontSize="11"
                                           Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                                <TextBlock Text="{Binding SelectedGalaxyMemory.ConstellationName}"
                                           Margin="0,0,0,16"
                                           FontSize="11"
                                           Foreground="{DynamicResource Perelegans.AccentBrush}"/>
                                <TextBlock Text="{Binding SelectedGalaxyMemory.InsightMetaText}"
                                           Margin="0,0,0,16"
                                           FontSize="11"
                                           Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>

                                <Grid Margin="0,0,0,8"
                                      Visibility="{Binding HasSelectedPendingMemory, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Content="确认进入星图"
                                            Command="{Binding ConfirmSelectedMemoryCommand}"
                                            HorizontalContentAlignment="Center"
                                            Style="{StaticResource AccentLineButtonStyle}"/>
                                    <Button Grid.Column="2"
                                            Content="忽略"
                                            Command="{Binding RejectSelectedMemoryCommand}"
                                            HorizontalContentAlignment="Center"
                                            Style="{StaticResource LineButtonStyle}"/>
                                </Grid>

                                <Button Content="{i18n:Translate Main_GalaxyTaskSave}"
                                        Command="{Binding SaveGalaxyTaskCommand}"
                                        HorizontalContentAlignment="Center"
                                        Style="{StaticResource AccentLineButtonStyle}"
                                        Margin="0,0,0,8"/>
                                <Button Content="{i18n:Translate Main_GalaxyTaskDelete}"
                                        Command="{Binding DeleteGalaxyTaskCommand}"
                                        HorizontalContentAlignment="Center"
                                        Style="{StaticResource LineButtonStyle}"
                                        Margin="0"/>
                            </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</mah:MetroWindow>
