<mah:MetroWindow x:Class="Perelegans.Views.AiReplayWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 Title="AI 工作现场"
                 Width="980"
                 Height="680"
                 MinWidth="760"
                 MinHeight="520"
                 WindowStartupLocation="CenterOwner"
                 Background="{DynamicResource Perelegans.WindowBackground}"
                 Foreground="{DynamicResource Perelegans.ForegroundBrush}">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,18">
            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        VerticalAlignment="Top">
                <Button Content="生成回放"
                        Command="{Binding GenerateUsageReplayCommand}"
                        Style="{StaticResource PresetButtonStyle}"
                        Margin="0,0,8,0"/>
                <Button Content="记忆体检"
                        Command="{Binding GenerateMemoryHealthCommand}"
                        Style="{StaticResource PresetButtonStyle}"
                        Margin="0,0,8,0"/>
                <Button Content="关闭"
                        Click="Close_Click"
                        Style="{StaticResource PresetButtonStyle}"
                        Margin="0"/>
            </StackPanel>
            <StackPanel>
                <TextBlock Text="AI 工作现场"
                           FontSize="24"
                           FontWeight="SemiBold"/>
                <TextBlock Text="把进程时间线、本地记忆、计划状态和当前窗口合成可解释的现场回放。"
                           Margin="0,5,0,0"
                           MaxWidth="620"
                           FontSize="13"
                           LineHeight="19"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
            </StackPanel>
        </DockPanel>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Padding="16"
                        Background="{DynamicResource Perelegans.StatsChartPanelBackground}"
                        BorderBrush="{DynamicResource Perelegans.StatsChartPanelBorderBrush}"
                        BorderThickness="1">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <TextBlock Text="{Binding UsageReplayCard.Title, TargetNullValue=AI 工作现场回放}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       DockPanel.Dock="Left"/>
                            <TextBlock Text="{Binding UsageReplayCard.Subtitle}"
                                       FontSize="11"
                                       HorizontalAlignment="Right"
                                       Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                        </DockPanel>

                        <TextBlock Text="点击“生成回放”，我会按时间切片解释你刚才在推进什么、在哪里切换、可能卡在哪里。"
                                   FontSize="13"
                                   LineHeight="20"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasUsageReplayCard}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <StackPanel Visibility="{Binding HasUsageReplayCard, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="{Binding UsageReplayCard.Summary}"
                                       FontSize="13"
                                       LineHeight="20"
                                       TextWrapping="Wrap"/>

                            <TextBlock Text="证据"
                                       Margin="0,14,0,7"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                            <ItemsControl ItemsSource="{Binding UsageReplayCard.Evidence}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   Margin="0,0,0,6"
                                                   FontSize="12"
                                                   LineHeight="18"
                                                   TextWrapping="Wrap"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border Padding="11,9"
                                    Margin="0,12,0,0"
                                    Background="{DynamicResource Perelegans.StatsChartHighlightBackground}"
                                    BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="下一步"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="#FFFF8FC3"/>
                                    <TextBlock Text="{Binding UsageReplayCard.NextAction}"
                                               Margin="0,5,0,0"
                                               FontSize="12"
                                               LineHeight="18"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Padding="16"
                        Background="{DynamicResource Perelegans.StatsChartPanelBackground}"
                        BorderBrush="{DynamicResource Perelegans.StatsChartPanelBorderBrush}"
                        BorderThickness="1">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <TextBlock Text="{Binding MemoryHealthCard.Title, TargetNullValue=AI 记忆体检}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       DockPanel.Dock="Left"/>
                            <TextBlock Text="{Binding MemoryHealthCard.Subtitle}"
                                       FontSize="11"
                                       HorizontalAlignment="Right"
                                       Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                        </DockPanel>

                        <TextBlock Text="点击“记忆体检”，我会检查过期计划、冲突线索、待确认记忆和星图聚类。"
                                   FontSize="13"
                                   LineHeight="20"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasMemoryHealthCard}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <StackPanel Visibility="{Binding HasMemoryHealthCard, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="{Binding MemoryHealthCard.Summary}"
                                       FontSize="13"
                                       LineHeight="20"
                                       TextWrapping="Wrap"/>

                            <TextBlock Text="维护建议"
                                       Margin="0,14,0,7"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                            <ItemsControl ItemsSource="{Binding MemoryHealthCard.PlanSuggestions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   Margin="0,0,0,6"
                                                   FontSize="12"
                                                   LineHeight="18"
                                                   TextWrapping="Wrap"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="星图解释"
                                       Margin="0,12,0,7"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                            <ItemsControl ItemsSource="{Binding MemoryHealthCard.ConstellationExplanations}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   Margin="0,0,0,6"
                                                   FontSize="12"
                                                   LineHeight="18"
                                                   TextWrapping="Wrap"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</mah:MetroWindow>
