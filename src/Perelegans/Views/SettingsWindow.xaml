<mah:MetroWindow x:Class="Perelegans.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:models="clr-namespace:Perelegans.Models"
        xmlns:i18n="clr-namespace:Perelegans.i18n"
        Title="{i18n:Translate Settings_WindowTitle}"
        TitleCharacterCasing="Normal"
        Height="680"
        Width="860"
        MinHeight="620"
        MinWidth="760"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ShowTitleBar="True"
        TitleBarHeight="32"
        BorderThickness="1"
        WindowTitleBrush="{DynamicResource Perelegans.PanelBackground}"
        NonActiveWindowTitleBrush="{DynamicResource Perelegans.PanelBackground}"
        GlowBrush="{DynamicResource Perelegans.BorderBrush}"
        Background="{DynamicResource Perelegans.WindowBackground}"
        Foreground="{DynamicResource Perelegans.ForegroundBrush}">

    <mah:MetroWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <ObjectDataProvider x:Key="ThemeModes" MethodName="GetValues" ObjectType="{x:Type models:ThemeMode}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:ThemeMode"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <Style x:Key="QuietTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource Perelegans.ForegroundBrush}"/>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource Perelegans.ForegroundBrush}"/>
        </Style>

        <Style x:Key="SettingsInputStyle" TargetType="Control">
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <DataTemplate x:Key="OptionLabelTemplate">
            <TextBlock Text="{Binding Label}"
                       Foreground="{DynamicResource Perelegans.ForegroundBrush}"/>
        </DataTemplate>

        <Style x:Key="SettingsComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource Perelegans.ForegroundBrush}"/>
            <Setter Property="Background" Value="{DynamicResource Perelegans.PanelBackground}"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Perelegans.MenuHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Perelegans.StatsChartHighlightBackground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource Perelegans.ForegroundBrush}"/>
            <Setter Property="Background" Value="{DynamicResource Perelegans.PanelBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Perelegans.BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource SettingsComboBoxItemStyle}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Chrome"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="34"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Margin="{TemplateBinding Padding}"
                                                                  VerticalAlignment="Center"
                                                                  HorizontalAlignment="Stretch"/>
                                                <Path Grid.Column="1"
                                                      Width="9"
                                                      Height="5"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Stretch="Fill"
                                                      Fill="{DynamicResource Perelegans.SubtleForegroundBrush}"
                                                      Data="M0,0 L9,0 L4.5,5 Z"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource Perelegans.AccentBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource Perelegans.AccentBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              Margin="10,0,34,0"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              VerticalAlignment="Center"/>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Background="{DynamicResource Perelegans.PanelBackground}"
                                        BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                                        BorderThickness="1">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LineButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource Perelegans.ForegroundBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Perelegans.MenuHoverBrush}"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource Perelegans.BorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Perelegans.StatsChartMetricBackground}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentLineButtonStyle" TargetType="Button" BasedOn="{StaticResource LineButtonStyle}">
            <Setter Property="BorderBrush" Value="{DynamicResource Perelegans.AccentBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource Perelegans.AccentBrush}"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="LineIconPathStyle" TargetType="Path">
            <Setter Property="Fill" Value="Transparent"/>
            <Setter Property="StrokeThickness" Value="1.45"/>
            <Setter Property="StrokeStartLineCap" Value="Round"/>
            <Setter Property="StrokeEndLineCap" Value="Round"/>
            <Setter Property="StrokeLineJoin" Value="Round"/>
            <Setter Property="Stretch" Value="Uniform"/>
        </Style>

        <Style x:Key="SectionShellStyle" TargetType="Border">
            <Setter Property="Padding" Value="0,0,0,26"/>
            <Setter Property="Margin" Value="0,0,0,26"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Perelegans.BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
    </mah:MetroWindow.Resources>

    <Grid Opacity="0">
        <Grid.Triggers>
            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.18"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Grid.Triggers>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Padding="16"
                Background="{DynamicResource Perelegans.PanelBackground}"
                BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="24"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="{i18n:Translate Settings_WindowTitle}" FontSize="19" FontWeight="SemiBold"/>
                    <TextBlock Text="Perelegans" Margin="0,6,0,0" Style="{StaticResource QuietTextStyle}"/>
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <Button Style="{StaticResource LineButtonStyle}" Margin="0,0,0,6" Click="AppearanceNav_Click">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="28" Height="18" Margin="0,0,8,0">
                                <Path Style="{StaticResource LineIconPathStyle}"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Data="{StaticResource Icon.SlidersHorizontal}"/>
                            </Viewbox>
                            <TextBlock Text="{i18n:Translate Settings_Appearance}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource LineButtonStyle}" Margin="0,0,0,6" Click="AiNav_Click">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="28" Height="18" Margin="0,0,8,0">
                                <Path Style="{StaticResource LineIconPathStyle}"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Data="{StaticResource Icon.Sparkles}"/>
                            </Viewbox>
                            <TextBlock Text="{i18n:Translate Settings_Ai}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource LineButtonStyle}" Margin="0,0,0,6" Click="MemoryNav_Click">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="28" Height="18" Margin="0,0,8,0">
                                <Path Style="{StaticResource LineIconPathStyle}"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Data="{StaticResource Icon.BrainCircuit}"/>
                            </Viewbox>
                            <TextBlock Text="{i18n:Translate Settings_Memory}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource LineButtonStyle}" Margin="0,0,0,6" Click="SystemNav_Click">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="28" Height="18" Margin="0,0,8,0">
                                <Path Style="{StaticResource LineIconPathStyle}"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Data="{StaticResource Icon.Settings}"/>
                            </Viewbox>
                            <TextBlock Text="{i18n:Translate Settings_System}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource LineButtonStyle}" Click="DataNav_Click">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="28" Height="18" Margin="0,0,8,0">
                                <Path Style="{StaticResource LineIconPathStyle}"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Data="{StaticResource Icon.Database}"/>
                            </Viewbox>
                            <TextBlock Text="{i18n:Translate Settings_Data}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Row="3">
                    <Button Content="{i18n:Translate Btn_Save}" Height="36" Margin="0,0,0,8" Style="{StaticResource AccentLineButtonStyle}" Click="BtnSave_Click"/>
                    <Button Content="{i18n:Translate Btn_Cancel}" Height="36" Style="{StaticResource LineButtonStyle}" HorizontalContentAlignment="Center" BorderBrush="{DynamicResource Perelegans.BorderBrush}" Click="BtnCancel_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer x:Name="SettingsScrollViewer" Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="34,28,38,28">
                <Border x:Name="AppearanceSection" Style="{StaticResource SectionShellStyle}">
                    <StackPanel>
                        <TextBlock Text="{i18n:Translate Settings_Appearance}" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock Text="{i18n:Translate Settings_ThemeMode}" Margin="0,20,0,8" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox Style="{StaticResource SettingsComboBoxStyle}" ItemsSource="{Binding Source={StaticResource ThemeModes}}" SelectedItem="{Binding SelectedTheme, Mode=TwoWay}"/>
                        <TextBlock Text="{i18n:Translate Settings_Language}" Margin="0,16,0,8" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox Style="{StaticResource SettingsComboBoxStyle}" ItemsSource="{Binding LanguageOptions}" SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}"/>
                    </StackPanel>
                </Border>

                <Border x:Name="AiSection" Style="{StaticResource SectionShellStyle}">
                    <StackPanel>
                        <TextBlock Text="{i18n:Translate Settings_Ai}" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock Text="{i18n:Translate Settings_AiProvider}" Margin="0,20,0,8" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox Style="{StaticResource SettingsComboBoxStyle}" ItemsSource="{Binding AiProviderOptions}" ItemTemplate="{StaticResource OptionLabelTemplate}" SelectedValuePath="Value" SelectedValue="{Binding SelectedAiProvider, Mode=TwoWay}"/>
                        <Border Margin="0,10,0,18" Padding="12,9" Background="{DynamicResource Perelegans.PanelBackground}" BorderBrush="{DynamicResource Perelegans.BorderBrush}" BorderThickness="1">
                            <TextBlock Text="{Binding AiProviderHint}" TextWrapping="Wrap" Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}" FontSize="12" LineHeight="18"/>
                        </Border>
                        <TextBlock Text="{i18n:Translate Settings_AiBaseUrl}" Margin="0,0,0,8" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Height="34" FontSize="13" VerticalContentAlignment="Center" Text="{Binding AiApiBaseUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" mah:TextBoxHelper.Watermark="{Binding AiBaseUrlPlaceholder}"/>
                        <TextBlock Text="{i18n:Translate Settings_AiApiKey}" Margin="0,16,0,8" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Height="34" FontSize="13" VerticalContentAlignment="Center" Text="{Binding AiApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" mah:TextBoxHelper.Watermark="{Binding AiApiKeyPlaceholder}"/>
                        <TextBlock Text="{i18n:Translate Settings_AiModel}" Margin="0,16,0,8" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Height="34" FontSize="13" VerticalContentAlignment="Center" Text="{Binding AiModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" mah:TextBoxHelper.Watermark="{Binding AiModelPlaceholder}"/>
                        <TextBlock Text="{i18n:Translate Settings_AiPersonalityPrompt}" Margin="0,16,0,8" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox MinHeight="96"
                                 FontSize="13"
                                 Padding="10,8"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding AiPersonalityPrompt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 mah:TextBoxHelper.Watermark="{i18n:Translate Settings_AiPersonalityPromptWatermark}"/>
                        <TextBlock Text="{i18n:Translate Settings_AiPersonalityPromptHint}"
                                   Margin="0,8,0,0"
                                   TextWrapping="Wrap"
                                   Style="{StaticResource QuietTextStyle}"/>
                        <Button Width="112"
                                Height="32"
                                Margin="0,10,0,0"
                                HorizontalAlignment="Left"
                                HorizontalContentAlignment="Center"
                                BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                                Style="{StaticResource LineButtonStyle}"
                                Content="{i18n:Translate Settings_AiPersonalityPromptReset}"
                                Command="{Binding ResetAiPersonalityPromptCommand}"/>
                        <DockPanel Margin="0,18,0,0" LastChildFill="True">
                            <Button DockPanel.Dock="Left" Width="112" Height="34" Margin="0,0,10,0" Style="{StaticResource AccentLineButtonStyle}" Content="{i18n:Translate Settings_AiTestButton}" Command="{Binding TestAiCommand}"/>
                            <Border Padding="12,9" Background="{DynamicResource Perelegans.PanelBackground}" BorderBrush="{DynamicResource Perelegans.BorderBrush}" BorderThickness="1" Visibility="{Binding HasAiTestStatus, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="{Binding AiTestStatusText}" TextWrapping="Wrap" Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}" FontSize="12"/>
                            </Border>
                        </DockPanel>
                    </StackPanel>
                </Border>

                <Border x:Name="MemorySection" Style="{StaticResource SectionShellStyle}">
                    <StackPanel>
                        <TextBlock Text="{i18n:Translate Settings_Memory}" Style="{StaticResource SectionTitleStyle}"/>
                        <CheckBox Content="{i18n:Translate Settings_MemoryAutoSave}"
                                  Margin="0,18,0,12"
                                  IsChecked="{Binding AutoSaveMemories, Mode=TwoWay}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="260"/>
                                <ColumnDefinition Width="18"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Height="260"
                                    BorderBrush="{DynamicResource Perelegans.BorderBrush}"
                                    BorderThickness="1"
                                    Background="{DynamicResource Perelegans.PanelBackground}">
                                <ListBox ItemsSource="{Binding Memories}"
                                         SelectedItem="{Binding SelectedMemory, Mode=TwoWay}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="{DynamicResource Perelegans.ForegroundBrush}"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="4,6">
                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding TypeText}" Margin="0,2,0,0" FontSize="11" Foreground="{DynamicResource Perelegans.AccentBrush}"/>
                                                <TextBlock Text="{Binding Preview}" Margin="0,3,0,0" FontSize="11" TextWrapping="Wrap" Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{i18n:Translate Settings_MemoryTitle}" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Height="34" Margin="0,7,0,12" Padding="8,0" VerticalContentAlignment="Center" Text="{Binding MemoryTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                <TextBlock Text="{i18n:Translate Settings_MemoryType}" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox Margin="0,7,0,12" Style="{StaticResource SettingsComboBoxStyle}" ItemsSource="{Binding MemoryTypeOptions}" SelectedItem="{Binding SelectedMemoryType, Mode=TwoWay}"/>

                                <TextBlock Text="{i18n:Translate Settings_MemoryContent}" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Height="92" Margin="0,7,0,12" Padding="8" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Text="{Binding MemoryContent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                <TextBlock Text="{i18n:Translate Settings_MemoryTags}" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Height="34" Margin="0,7,0,14" Padding="8,0" VerticalContentAlignment="Center" Text="{Binding MemoryTags, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                <StackPanel Orientation="Horizontal">
                                    <Button Width="82" Height="34" Margin="0,0,8,0" Style="{StaticResource LineButtonStyle}" HorizontalContentAlignment="Center" BorderBrush="{DynamicResource Perelegans.BorderBrush}" Content="{i18n:Translate Settings_MemoryNew}" Command="{Binding NewMemoryCommand}"/>
                                    <Button Width="82" Height="34" Margin="0,0,8,0" Style="{StaticResource AccentLineButtonStyle}" Content="{i18n:Translate Settings_MemorySave}" Command="{Binding SaveMemoryCommand}"/>
                                    <Button Width="82" Height="34" Margin="0,0,8,0" Style="{StaticResource LineButtonStyle}" HorizontalContentAlignment="Center" BorderBrush="{DynamicResource Perelegans.BorderBrush}" Content="{i18n:Translate Settings_MemoryDelete}" Command="{Binding DeleteMemoryCommand}"/>
                                    <Button Width="82" Height="34" Style="{StaticResource LineButtonStyle}" HorizontalContentAlignment="Center" BorderBrush="{DynamicResource Perelegans.BorderBrush}" Content="{i18n:Translate Settings_MemoryClear}" Command="{Binding ClearMemoriesCommand}"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                        <Border Margin="0,12,0,0" Padding="12,9" Background="{DynamicResource Perelegans.PanelBackground}" BorderBrush="{DynamicResource Perelegans.BorderBrush}" BorderThickness="1" Visibility="{Binding HasMemoryStatus, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="{Binding MemoryStatusText}" TextWrapping="Wrap" Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}" FontSize="12"/>
                        </Border>
                    </StackPanel>
                </Border>

                <Border x:Name="SystemSection" Style="{StaticResource SectionShellStyle}">
                    <StackPanel>
                        <TextBlock Text="{i18n:Translate Settings_System}" Style="{StaticResource SectionTitleStyle}"/>
                        <Grid Margin="0,20,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="14"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="14"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="{i18n:Translate Settings_LaunchAtStartup}" Style="{StaticResource FieldLabelStyle}"/>
                            <CheckBox Grid.Row="0" Grid.Column="1" IsChecked="{Binding LaunchAtStartup, Mode=TwoWay}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="2" Text="{i18n:Translate Settings_CloseBehavior}" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox Grid.Row="2" Grid.Column="1" Style="{StaticResource SettingsComboBoxStyle}" ItemsSource="{Binding CloseBehaviorOptions}" ItemTemplate="{StaticResource OptionLabelTemplate}" SelectedValuePath="Value" SelectedValue="{Binding SelectedCloseBehavior, Mode=TwoWay}"/>
                            <TextBlock Grid.Row="4" Text="Coding clients:" Style="{StaticResource FieldLabelStyle}"/>
                            <StackPanel Grid.Row="4" Grid.Column="1">
                                <CheckBox Content="Enable coding client monitor"
                                          IsChecked="{Binding CodingClientMonitorEnabled, Mode=TwoWay}"
                                          VerticalAlignment="Center"/>
                                <CheckBox Content="Codex Desktop"
                                          Margin="0,9,0,0"
                                          IsChecked="{Binding CodexDesktopMonitorEnabled, Mode=TwoWay}"
                                          IsEnabled="{Binding CodingClientMonitorEnabled}"
                                          VerticalAlignment="Center"/>
                                <CheckBox Content="Claude Desktop"
                                          Margin="0,9,0,0"
                                          IsChecked="{Binding ClaudeDesktopMonitorEnabled, Mode=TwoWay}"
                                          IsEnabled="{Binding CodingClientMonitorEnabled}"
                                          VerticalAlignment="Center"/>
                                <TextBlock Text="Uses client process activity, local state timestamps, Windows notifications, and active workspace file changes when available."
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap"
                                           Style="{StaticResource QuietTextStyle}"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="专注应用规则"
                                   Margin="0,20,0,8"
                                   Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox MinHeight="92"
                                 FontSize="13"
                                 Padding="10,8"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding ProductiveProcessRules, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="每行一个进程名、窗口标题关键词或路径关键词；命中后会作为专注/生产力信号。"
                                   Margin="0,8,0,0"
                                   TextWrapping="Wrap"
                                   Style="{StaticResource QuietTextStyle}"/>
                        <Grid Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="离开多久生成断点"
                                       VerticalAlignment="Center"
                                       Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Grid.Column="1"
                                     Height="34"
                                     Padding="8,0"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding BreakpointIdleThresholdMinutes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Grid.Column="3"
                                       Text="回来多久弹出恢复"
                                       VerticalAlignment="Center"
                                       Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Grid.Column="4"
                                     Height="34"
                                     Padding="8,0"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding BreakpointReturnThresholdSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border x:Name="DataSection" Padding="0">
                    <StackPanel>
                        <TextBlock Text="{i18n:Translate Settings_Data}" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock Text="{i18n:Translate Settings_DataActions}" Margin="0,20,0,10" Style="{StaticResource FieldLabelStyle}"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Width="112" Height="34" Margin="0,0,10,0" Style="{StaticResource LineButtonStyle}" HorizontalContentAlignment="Center" BorderBrush="{DynamicResource Perelegans.BorderBrush}" Content="{i18n:Translate Main_Backup}" Command="{Binding SaveBackupCommand}"/>
                            <Button Width="112" Height="34" Style="{StaticResource LineButtonStyle}" HorizontalContentAlignment="Center" BorderBrush="{DynamicResource Perelegans.BorderBrush}" Content="{i18n:Translate Main_Restore}" Command="{Binding RestoreBackupCommand}"/>
                        </StackPanel>
                        <Border Margin="0,12,0,0" Padding="12,9" Background="{DynamicResource Perelegans.PanelBackground}" BorderBrush="{DynamicResource Perelegans.BorderBrush}" BorderThickness="1" Visibility="{Binding HasDataMaintenanceStatus, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="{Binding DataMaintenanceStatusText}" TextWrapping="Wrap" Foreground="{DynamicResource Perelegans.SubtleForegroundBrush}" FontSize="12"/>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</mah:MetroWindow>
