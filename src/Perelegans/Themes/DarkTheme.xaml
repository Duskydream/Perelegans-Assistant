<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <!-- Perelegans Dark Theme: Obsidian-like dark surface + quiet pink accent -->

    <!-- Window & Panel Backgrounds -->
    <SolidColorBrush x:Key="Perelegans.WindowBackground" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="Perelegans.PanelBackground" Color="#242424"/>
    <SolidColorBrush x:Key="Perelegans.StatsChartPanelBackground" Color="#171B22"/>
    <SolidColorBrush x:Key="Perelegans.StatsChartPanelBorderBrush" Color="#2E3A48"/>
    <SolidColorBrush x:Key="Perelegans.StatsChartMetricBackground" Color="#1D2430"/>
    <SolidColorBrush x:Key="Perelegans.StatsChartSliceBorderBrush" Color="#10151D"/>
    <SolidColorBrush x:Key="Perelegans.StatsChartHighlightBackground" Color="#142B34"/>
    <SolidColorBrush x:Key="Perelegans.StatsChartHighlightBorderBrush" Color="#54E8FF"/>
    
    <!-- Accent (slightly desaturated pink for dark-mode contrast) -->
    <Color x:Key="Perelegans.AccentColor">#DFA8B5</Color>
    <SolidColorBrush x:Key="Perelegans.AccentBrush" Color="#DFA8B5"/>
    <SolidColorBrush x:Key="Perelegans.AccentHoverBrush" Color="#E8BAC4"/>
    <SolidColorBrush x:Key="MahApps.Brushes.Accent" Color="#DFA8B5"/>
    
    <!-- Typography -->
    <SolidColorBrush x:Key="Perelegans.ForegroundBrush" Color="#D8D8D8"/>
    <SolidColorBrush x:Key="Perelegans.SubtleForegroundBrush" Color="#A0A0A0"/>
    <SolidColorBrush x:Key="Perelegans.StatusBarValueForegroundBrush" Color="#C6C6C6"/>
    <SolidColorBrush x:Key="Perelegans.DataGridSelectedPrimaryForegroundBrush" Color="#000000"/>
    <SolidColorBrush x:Key="Perelegans.StatusIconBrush" Color="#DFA8B5"/>
    
    <!-- Borders -->
    <SolidColorBrush x:Key="Perelegans.BorderBrush" Color="#363636"/>
    <SolidColorBrush x:Key="Perelegans.ButtonBorderBrush" Color="#363636"/>
    
    <!-- DataGrid -->
    <SolidColorBrush x:Key="Perelegans.DataGridAltRowBrush" Color="#222222"/>
    <SolidColorBrush x:Key="Perelegans.DataGridHeaderBackground" Color="#292929"/>
    <SolidColorBrush x:Key="Perelegans.DataGridSelectedRowBrush" Color="#3A3034"/>
    
    <!-- StatusBar -->
    <SolidColorBrush x:Key="Perelegans.StatusBarBackground" Color="#191919"/>
    
    <!-- Menu -->
    <SolidColorBrush x:Key="Perelegans.MenuBackground" Color="#202020"/>
    <SolidColorBrush x:Key="Perelegans.MenuHoverBrush" Color="#2E2E2E"/>

</ResourceDictionary>
