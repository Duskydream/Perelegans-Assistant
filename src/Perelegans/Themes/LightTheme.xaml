<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <!-- Perelegans Light Theme: Off-white (米白) + Pink -->

    <!-- Window & Panel Backgrounds -->
    <SolidColorBrush x:Key="Perelegans.WindowBackground" Color="#F8F7F3"/>
    <SolidColorBrush x:Key="Perelegans.PanelBackground" Color="#EFEEE9"/>
    <SolidColorBrush x:Key="Perelegans.StatsChartPanelBackground" Color="#F8F7F3"/>
    <SolidColorBrush x:Key="Perelegans.StatsChartPanelBorderBrush" Color="#CFCBC1"/>
    <SolidColorBrush x:Key="Perelegans.StatsChartMetricBackground" Color="#E7E4DC"/>
    <SolidColorBrush x:Key="Perelegans.StatsChartSliceBorderBrush" Color="#F8F7F3"/>
    <SolidColorBrush x:Key="Perelegans.StatsChartHighlightBackground" Color="#FBE3EA"/>
    <SolidColorBrush x:Key="Perelegans.StatsChartHighlightBorderBrush" Color="#B84F73"/>
    
    <!-- Accent -->
    <Color x:Key="Perelegans.AccentColor">#C94D78</Color>
    <SolidColorBrush x:Key="Perelegans.AccentBrush" Color="#C94D78"/>
    <SolidColorBrush x:Key="Perelegans.AccentHoverBrush" Color="#AD3E65"/>
    <SolidColorBrush x:Key="MahApps.Brushes.Accent" Color="#C94D78"/>
    
    <!-- Typography -->
    <SolidColorBrush x:Key="Perelegans.ForegroundBrush" Color="#14161B"/>
    <SolidColorBrush x:Key="Perelegans.SubtleForegroundBrush" Color="#525A66"/>
    <SolidColorBrush x:Key="Perelegans.StatusBarValueForegroundBrush" Color="#14161B"/>
    <SolidColorBrush x:Key="Perelegans.DataGridSelectedPrimaryForegroundBrush" Color="#3A0F22"/>
    <SolidColorBrush x:Key="Perelegans.StatusIconBrush" Color="#B84F73"/>
    
    <!-- Borders -->
    <SolidColorBrush x:Key="Perelegans.BorderBrush" Color="#D2CEC4"/>
    <SolidColorBrush x:Key="Perelegans.ButtonBorderBrush" Color="#C8C3B8"/>
    
    <!-- DataGrid -->
    <SolidColorBrush x:Key="Perelegans.DataGridAltRowBrush" Color="#F1EFE8"/>
    <SolidColorBrush x:Key="Perelegans.DataGridHeaderBackground" Color="#E7E4DC"/>
    <SolidColorBrush x:Key="Perelegans.DataGridSelectedRowBrush" Color="#F9D7E1"/>
    
    <!-- StatusBar -->
    <SolidColorBrush x:Key="Perelegans.StatusBarBackground" Color="#E7E4DC"/>
    
    <!-- Menu -->
    <SolidColorBrush x:Key="Perelegans.MenuBackground" Color="#F8F7F3"/>
    <SolidColorBrush x:Key="Perelegans.MenuHoverBrush" Color="#E4E1D8"/>

</ResourceDictionary>
