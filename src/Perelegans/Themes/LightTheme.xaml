<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <!-- Perelegans Light Theme: Off-white (米白) + Pink -->

    <!-- Window & Panel Backgrounds -->
    <SolidColorBrush x:Key="Perelegans.WindowBackground" Color="#FAFAFA"/>
    <SolidColorBrush x:Key="Perelegans.PanelBackground" Color="#F3F3F3"/>
    <SolidColorBrush x:Key="Perelegans.StatsChartPanelBackground" Color="#FAFAFA"/>
    <SolidColorBrush x:Key="Perelegans.StatsChartPanelBorderBrush" Color="#DADADA"/>
    <SolidColorBrush x:Key="Perelegans.StatsChartMetricBackground" Color="#ECECEC"/>
    <SolidColorBrush x:Key="Perelegans.StatsChartSliceBorderBrush" Color="#FAFAFA"/>
    <SolidColorBrush x:Key="Perelegans.StatsChartHighlightBackground" Color="#FFF1F4"/>
    <SolidColorBrush x:Key="Perelegans.StatsChartHighlightBorderBrush" Color="#C98796"/>
    
    <!-- Accent -->
    <Color x:Key="Perelegans.AccentColor">#E7B4BF</Color>
    <SolidColorBrush x:Key="Perelegans.AccentBrush" Color="#E7B4BF"/>
    <SolidColorBrush x:Key="Perelegans.AccentHoverBrush" Color="#F0C5CE"/>
    <SolidColorBrush x:Key="MahApps.Brushes.Accent" Color="#E7B4BF"/>
    
    <!-- Typography -->
    <SolidColorBrush x:Key="Perelegans.ForegroundBrush" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="Perelegans.SubtleForegroundBrush" Color="#6F6F6F"/>
    <SolidColorBrush x:Key="Perelegans.StatusBarValueForegroundBrush" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="Perelegans.DataGridSelectedPrimaryForegroundBrush" Color="#5D1135"/>
    <SolidColorBrush x:Key="Perelegans.StatusIconBrush" Color="#C98796"/>
    
    <!-- Borders -->
    <SolidColorBrush x:Key="Perelegans.BorderBrush" Color="#DDDDDD"/>
    <SolidColorBrush x:Key="Perelegans.ButtonBorderBrush" Color="#DDDDDD"/>
    
    <!-- DataGrid -->
    <SolidColorBrush x:Key="Perelegans.DataGridAltRowBrush" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="Perelegans.DataGridHeaderBackground" Color="#EEEEEE"/>
    <SolidColorBrush x:Key="Perelegans.DataGridSelectedRowBrush" Color="#FFE9EE"/>
    
    <!-- StatusBar -->
    <SolidColorBrush x:Key="Perelegans.StatusBarBackground" Color="#EEEEEE"/>
    
    <!-- Menu -->
    <SolidColorBrush x:Key="Perelegans.MenuBackground" Color="#FAFAFA"/>
    <SolidColorBrush x:Key="Perelegans.MenuHoverBrush" Color="#EDEDED"/>

</ResourceDictionary>
